<section class="slide layout-standard layout-scrollable{% if is_annex %} annex{% endif %} {% if is_diagram_only %}diagram-only{% endif %}" data-index="{{ index }}" id="{{ slide_id }}" data-id="{{ slide_id }}"{% if is_annex %} data-annex="true"{% endif %}{% if speaker_notes %} data-notes="{{ speaker_notes | escape }}"{% endif %}>
  {% if bg_image %}
  <div class="slide-bg-overlay" style="background-image: url('{{ bg_image.src }}'); {% if bg_image.opacity %}opacity: {{ bg_image.opacity }};{% endif %}"></div>
  {% endif %}
  <div class="slide-header">
    {% if is_annex %}
    <button class="btn-volver">← Volver</button>
    {% endif %}
    {% if eyebrow %}<div class="eyebrow">{{ eyebrow | safe }}</div>{% endif %}
    {% if heading %}<h1 class="slide-h1">{{ heading | safe }}</h1>{% endif %}
    {% if subtitle %}<h2 class="slide-h2">{{ subtitle | safe }}</h2>{% endif %}
  </div>
  <div class="slide-body">
    {% for el in body_elements %}
    {{ el | safe }}
    {% endfor %}
  </div>
  {% if footer_text or logo %}
  <div class="slide-footer">
    {% if footer_text %}<span class="footer-text">{{ footer_text }}</span>{% endif %}
    {% if logo %}<span class="footer-logo"></span>{% endif %}
  </div>
  {% endif %}
</section>
