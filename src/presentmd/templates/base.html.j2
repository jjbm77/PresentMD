      const offset = circ * (1 - val / 100);
      el.style.setProperty('--ring-offset', `${offset}px`);
    });

    if (document.startViewTransition) {
      document.documentElement.classList.add('view-transitions-supported');
    }
    const slides = Array.from(document.querySelectorAll('.slide'));
    const total = slides.length;
    let current = 0;
    let history = [];
    let laserActive = false;

    const progressFill = document.getElementById('progressFill');
    const counter = document.getElementById('slideCounter');
    const navPill = document.getElementById('navPillContainer');
    const fabContainer = document.getElementById('fabContainer');
    const tocSidebar = document.getElementById('tocSidebar');
    const tocOverlay = document.getElementById('tocOverlay');
    const laser = document.getElementById('laserPointer');
    const container = document.getElementById('presentationContainer');

    // M4: Identify annexes and normal slides sequence
    const normalSequence = [];
    let normalCount = 0;
    slides.forEach((s, idx) => {
      const isAnnex = s.classList.contains('annex') || s.dataset.annex === 'true';
      if (!isAnnex) {
        normalCount++;
        normalSequence[idx] = normalCount;
      } else {
        normalSequence[idx] = null;
      }
    });

    const spotlightOverlay = document.getElementById('spotlightOverlay');
    const spotlightTooltip = document.getElementById('spotlightTooltip');
    const drawingCanvas = document.getElementById('drawingCanvas');
    const drawBtn = document.getElementById('drawBtn');
    const clearBtn = document.getElementById('clearBtn');
    const laserBtn = document.getElementById('laserBtn');

    let drawingActive = false;
    let isDrawing = false;
    let lastX = 0;
    let lastY = 0;
    let canvasCtx = null;
    const savedDrawings = {};
    if (drawingCanvas) {
      canvasCtx = drawingCanvas.getContext('2d');
    }

    let currentSpotlightTarget = null;

    function showSpotlight(selector, content) {
      if (!spotlightOverlay || !spotlightTooltip) return;
      const target = document.querySelector(selector);
      if (!target) {
        hideSpotlight();
        return;
      }
      if (currentSpotlightTarget && currentSpotlightTarget !== target) {
        currentSpotlightTarget.classList.remove('spotlight-active-target');
      }
      currentSpotlightTarget = target;
      currentSpotlightTarget.classList.add('spotlight-active-target');

      const rect = target.getBoundingClientRect();
      const x = rect.left + rect.width / 2;
      const y = rect.top + rect.height / 2;
      const radius = Math.max(rect.width, rect.height) / 2 + 15;

      spotlightOverlay.style.setProperty('--spotlight-x', `${x}px`);
      spotlightOverlay.style.setProperty('--spotlight-y', `${y}px`);
      spotlightOverlay.style.setProperty('--spotlight-radius', `${radius}px`);

      const maskVal = `radial-gradient(circle at ${x}px ${y}px, transparent ${radius}px, black ${radius + 5}px)`;
      spotlightOverlay.style.maskImage = maskVal;
      spotlightOverlay.style.webkitMaskImage = maskVal;

      spotlightOverlay.classList.add('active');

      spotlightTooltip.innerHTML = content;
      spotlightTooltip.style.display = 'block';

      const tooltipRect = spotlightTooltip.getBoundingClientRect();
      let top = rect.bottom + 20;
      if (top + tooltipRect.height > window.innerHeight) {
        top = rect.top - tooltipRect.height - 20;
      }
      let left = rect.left + (rect.width - tooltipRect.width) / 2;
      left = Math.max(10, Math.min(left, window.innerWidth - tooltipRect.width - 10));

      spotlightTooltip.style.top = `${top}px`;
      spotlightTooltip.style.left = `${left}px`;
    }

    function hideSpotlight() {
      if (currentSpotlightTarget) {
        currentSpotlightTarget.classList.remove('spotlight-active-target');
        currentSpotlightTarget = null;
      }
      if (spotlightOverlay) spotlightOverlay.classList.remove('active');
      if (spotlightTooltip) spotlightTooltip.style.display = 'none';
    }

    function autoScaleSlideContent(slide) {
      if (!slide) return;
      document.documentElement.style.fontSize = '16px';
      let scaleFactor = 1.0;
      let limit = 100;
      while (slide.scrollHeight > 720 && limit >= 60) {
        limit -= 2;
        scaleFactor = limit / 100;
        document.documentElement.style.fontSize = (16 * scaleFactor) + 'px';
      }
    }

    function scaleSlides() {
      const vw = window.innerWidth;
      const vh = window.innerHeight;
      const scaleX = vw / 1280;
      const scaleY = vh / 720;
      const scale = Math.min(scaleX, scaleY);
      slides.forEach(s => {
        s.style.transform = `scale(${scale})`;
        s.style.transformOrigin = 'top left';
        s.style.left = ((vw - 1280 * scale) / 2) + 'px';
        s.style.top = ((vh - 720 * scale) / 2) + 'px';
      });
      if (drawingCanvas) {
        drawingCanvas.width = vw;
        drawingCanvas.height = vh;
      }
      autoScaleSlideContent(slides[current]);
    }

    let slideSteps = [];
    let currentSlideStepIndex = 0;

    function resizeHotspotsLayers() {
      document.querySelectorAll('.hotspots-container').forEach(container => {
        const img = container.querySelector('.hotspots-image');
        const layer = container.querySelector('.hotspots-pins-layer');
        if (img && layer) {
          const imgWidth = img.naturalWidth;
          const imgHeight = img.naturalHeight;
          if (!imgWidth || !imgHeight) return;
          
          const containerWidth = container.clientWidth;
          const containerHeight = container.clientHeight;
          
          const containerRatio = containerWidth / containerHeight;
          const imgRatio = imgWidth / imgHeight;
          
          let renderedWidth, renderedHeight;
          if (imgRatio > containerRatio) {
            renderedWidth = containerWidth;
            renderedHeight = containerWidth / imgRatio;
          } else {
            renderedHeight = containerHeight;
            renderedWidth = containerHeight * imgRatio;
          }
          
          layer.style.width = `${renderedWidth}px`;
          layer.style.height = `${renderedHeight}px`;
          layer.style.left = `${(containerWidth - renderedWidth) / 2}px`;
          layer.style.top = `${(containerHeight - renderedHeight) / 2}px`;
          layer.style.position = 'absolute';
        }
      });
    }

    window.addEventListener('resize', resizeHotspotsLayers);
    window.addEventListener('load', resizeHotspotsLayers);

    function setupHotspotImageListeners() {
      document.querySelectorAll('.hotspots-image').forEach(img => {
        if (img.complete) {
          resizeHotspotsLayers();
        } else {
          img.addEventListener('load', resizeHotspotsLayers);
        }
      });
    }

    // Call on load
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setupHotspotImageListeners);
    } else {
      setupHotspotImageListeners();
    }

    function prepareSlideSteps(slideIdx, direction) {
      slideSteps = [];
      const slide = slides[slideIdx];
      if (!slide) return;

      const hotspotPins = slide.querySelectorAll('.hotspots-container .hotspot-pin');

      // 1. Steps list
      const stepsItems = slide.querySelectorAll('[data-step], .step-hidden, .step-visible');
      if (stepsItems.length > 0) {
        stepsItems.forEach((item) => {
          slideSteps.push({
            type: 'list-step',
            element: item,
            action: () => {
              item.classList.add('step-visible');
              item.classList.remove('step-hidden');
            },
            undo: () => {
              item.classList.remove('step-visible');
              item.classList.add('step-hidden');
            }
          });
        });
      }

      // 2. Layer stack
      const layerImages = slide.querySelectorAll('.layer-stack .layer-image');
      if (layerImages.length > 1) {
        for (let i = 1; i < layerImages.length; i++) {
          const img = layerImages[i];
          slideSteps.push({
            type: 'layer-step',
            element: img,
            action: () => {
              img.classList.add('active');
              img.classList.remove('layer-hidden');
            },
            undo: () => {
              img.classList.remove('active');
              img.classList.add('layer-hidden');
            }
          });
        }
      }

      // 3. Code stepping
      const codeStepping = slide.querySelectorAll('.code-container.stepping');
      codeStepping.forEach(container => {
        const stepsData = container.getAttribute('data-code-steps');
        if (stepsData) {
          try {
            const steps = JSON.parse(stepsData);
            if (steps.length > 1) {
              for (let i = 1; i < steps.length; i++) {
                const linesToHighlight = steps[i];
                const prevLinesToHighlight = steps[i - 1];
                const stepIdx = i;
                slideSteps.push({
                  type: 'code-step',
                  element: container,
                  action: () => {
                    container.setAttribute('data-active-step', stepIdx);
                    const allLines = container.querySelectorAll('.code-line');
                    allLines.forEach(line => {
                      const lineNum = parseInt(line.getAttribute('data-line') || '0', 10);
                      if (linesToHighlight.includes(lineNum)) {
                        line.classList.add('highlight-active');
                      } else {
                        line.classList.remove('highlight-active');
                      }
                    });
                  },
                  undo: () => {
                    container.setAttribute('data-active-step', stepIdx - 1);
                    const allLines = container.querySelectorAll('.code-line');
                    allLines.forEach(line => {
                      const lineNum = parseInt(line.getAttribute('data-line') || '0', 10);
                      if (prevLinesToHighlight.includes(lineNum)) {
                        line.classList.add('highlight-active');
                      } else {
                        line.classList.remove('highlight-active');
                      }
                    });
                  }
                });
              }
            }
          } catch (e) {
            console.error('Error parsing code steps JSON', e);
          }
        }
      });

      // 3.6 Spotlight stepping & Mouse Activation
      const spotlightConfig = slide.querySelector('.spotlight-config');
      let spotlightSteps = [];
      if (spotlightConfig) {
        const stepsData = spotlightConfig.getAttribute('data-spotlight-steps');
        if (stepsData) {
          try {
            spotlightSteps = JSON.parse(stepsData);
            spotlightSteps.forEach((step, stepIdx) => {
              slideSteps.push({
                type: 'spotlight-step',
                element: spotlightConfig,
                action: () => {
                  showSpotlight(step.selector, step.content);
                },
                undo: () => {
                  if (stepIdx > 0) {
                    showSpotlight(spotlightSteps[stepIdx - 1].selector, spotlightSteps[stepIdx - 1].content);
                  } else {
                    hideSpotlight();
                  }
                }
              });

              // Bind mouse listeners to the target element
              const target = slide.querySelector(step.selector) || document.querySelector(step.selector);
              if (target) {
                target.style.cursor = 'zoom-in';
                if (target._spotlightClickHandler) {
                  target.removeEventListener('click', target._spotlightClickHandler);
                }
                target._spotlightClickHandler = (e) => {
                  e.stopPropagation();
                  showSpotlight(step.selector, step.content);
                  const firstSpotlightIdx = slideSteps.findIndex(s => s.type === 'spotlight-step' && s.element === spotlightConfig);
                  if (firstSpotlightIdx !== -1) {
                    currentSlideStepIndex = firstSpotlightIdx + stepIdx + 1;
                  }
                };
                target.addEventListener('click', target._spotlightClickHandler);
              }
            });
          } catch(e) {
            console.error('Error parsing spotlight steps', e);
          }
        }
      }

      // Sort slideSteps according to their elements' DOM position
      slideSteps.sort((a, b) => {
        if (!a.element || !b.element) return 0;
        if (a.element === b.element) return 0;
        const position = a.element.compareDocumentPosition(b.element);
        if (position & Node.DOCUMENT_POSITION_FOLLOWING) return -1;
        if (position & Node.DOCUMENT_POSITION_PRECEDING) return 1;
        return 0;
      });

      // Initialize states based on direction
      if (direction === 'forward') {
        stepsItems.forEach(item => {
          item.classList.remove('step-visible');
          item.classList.add('step-hidden');
        });
        layerImages.forEach((img, idx) => {
          if (idx === 0) {
            img.classList.add('active');
            img.classList.remove('layer-hidden');
          } else {
            img.classList.remove('active');
            img.classList.add('layer-hidden');
          }
        });
        codeStepping.forEach(container => {
          container.setAttribute('data-active-step', '0');
          const stepsData = container.getAttribute('data-code-steps');
          if (stepsData) {
            try {
              const steps = JSON.parse(stepsData);
              if (steps.length > 0) {
                const firstStepLines = steps[0];
                const allLines = container.querySelectorAll('.code-line');
                allLines.forEach(line => {
                  const lineNum = parseInt(line.getAttribute('data-line') || '0', 10);
                  if (firstStepLines.includes(lineNum)) {
                    line.classList.add('highlight-active');
                  } else {
                    line.classList.remove('highlight-active');
                  }
                });
              }
            } catch (e) {}
          }
        });
        hotspotPins.forEach(pin => pin.classList.remove('active'));
        currentSlideStepIndex = 0;
      } else {
        stepsItems.forEach(item => {
          item.classList.add('step-visible');
          item.classList.remove('step-hidden');
        });
        layerImages.forEach(img => {
          img.classList.add('active');
          img.classList.remove('layer-hidden');
        });
        codeStepping.forEach(container => {
          const stepsData = container.getAttribute('data-code-steps');
          if (stepsData) {
            try {
              const steps = JSON.parse(stepsData);
              if (steps.length > 0) {
                const lastIdx = steps.length - 1;
                container.setAttribute('data-active-step', lastIdx);
                const lastStepLines = steps[lastIdx];
                const allLines = container.querySelectorAll('.code-line');
                allLines.forEach(line => {
                  const lineNum = parseInt(line.getAttribute('data-line') || '0', 10);
                  if (lastStepLines.includes(lineNum)) {
                    line.classList.add('highlight-active');
                  } else {
                    line.classList.remove('highlight-active');
                  }
                });
              }
            } catch (e) {}
          }
        });
        hotspotPins.forEach(pin => pin.classList.remove('active'));
        currentSlideStepIndex = slideSteps.length;
      }
    }

    function activateSlideSteps(slideIdx, direction) {
      const slide = slides[slideIdx];
      if (!slide) return;

      resizeHotspotsLayers();

      const spotlightConfig = slide.querySelector('.spotlight-config');
      if (spotlightConfig) {
        if (direction === 'forward') {
          hideSpotlight();
        } else {
          const stepsData = spotlightConfig.getAttribute('data-spotlight-steps');
          if (stepsData) {
            try {
              const spotlightSteps = JSON.parse(stepsData);
              if (spotlightSteps.length > 0) {
                const lastStep = spotlightSteps[spotlightSteps.length - 1];
                showSpotlight(lastStep.selector, lastStep.content);
              }
            } catch(e) {}
          }
        }
      } else {
        hideSpotlight();
      }
    }

    function handleNext() {
      if (currentSlideStepIndex < slideSteps.length) {
        slideSteps[currentSlideStepIndex].action();
        currentSlideStepIndex++;
      } else {
        next();
      }
    }

    function handlePrev() {
      if (currentSlideStepIndex > 0) {
        currentSlideStepIndex--;
        slideSteps[currentSlideStepIndex].undo();
      } else {
        prev();
      }
    }

    let controlsTimeout = null;
    let isInteractingWithControls = false;

    function resetControlsTimeout() {
      if (controlsTimeout) clearTimeout(controlsTimeout);
      if (isInteractingWithControls) return;
      
      controlsTimeout = setTimeout(() => {
        const isFabActive = fabContainer && fabContainer.classList.contains('active');
        if (!isFabActive && !isInteractingWithControls) {
          if (navPill) navPill.classList.add('fade-out');
          if (fabContainer) fabContainer.classList.add('fade-out');
        }
      }, 2500);
    }

    function showControlsWithFade() {
      if (navPill) navPill.classList.remove('fade-out');
      if (fabContainer) fabContainer.classList.remove('fade-out');
      resetControlsTimeout();
    }

    // Set up interaction listeners
    [navPill, fabContainer].forEach(el => {
      if (el) {
        el.addEventListener('mouseenter', () => {
          isInteractingWithControls = true;
          if (controlsTimeout) clearTimeout(controlsTimeout);
          if (navPill) navPill.classList.remove('fade-out');
          if (fabContainer) fabContainer.classList.remove('fade-out');
        });
        el.addEventListener('mouseleave', () => {
          isInteractingWithControls = false;
          resetControlsTimeout();
        });
      }
    });

    // Toggle FAB trigger
    const fabTrigger = document.getElementById('fabTrigger');
    if (fabTrigger && fabContainer) {
      fabTrigger.addEventListener('click', function(e) {
        e.stopPropagation();
        fabContainer.classList.toggle('active');
        showControlsWithFade();
      });
      // Close FAB if click outside
      document.addEventListener('click', function(e) {
        if (!fabContainer.contains(e.target)) {
          fabContainer.classList.remove('active');
          resetControlsTimeout();
        }
      });

      // Capture-phase listener to block background interactions during active spotlight
      document.addEventListener('click', function(e) {
        if (spotlightOverlay && spotlightOverlay.classList.contains('active')) {
          const clickedTarget = currentSpotlightTarget && currentSpotlightTarget.contains(e.target);
          const clickedTooltip = spotlightTooltip && spotlightTooltip.contains(e.target);
          if (!clickedTarget && !clickedTooltip) {
            e.stopPropagation();
            e.preventDefault();
            hideSpotlight();
          }
        }
      }, true);
    }

    function goTo(idx, direction = 'forward') {
      if (idx < 0 || idx >= total) return;

      const performGoTo = () => {
        hideSpotlight();
        
        if (drawingCanvas) {
          savedDrawings[current] = drawingCanvas.toDataURL();
        }
        
        // Prepare steps for the new slide before it becomes active in the DOM
        prepareSlideSteps(idx, direction);

        slides[current].classList.remove('active');
        current = idx;
        slides[current].classList.add('active');
        slides[current].offsetHeight; // Force reflow
        autoScaleSlideContent(slides[current]);
        
        // Activate steps that require layout measurements
        activateSlideSteps(current, direction);
        onSlideActive(current);

        if (drawingCanvas && canvasCtx) {
          canvasCtx.clearRect(0, 0, drawingCanvas.width, drawingCanvas.height);
          if (savedDrawings[current]) {
            const img = new Image();
            img.onload = () => {
              canvasCtx.drawImage(img, 0, 0);
            };
            img.src = savedDrawings[current];
          }
        }

        try {
          sessionStorage.setItem('pmd_current_slide', current);
        } catch (e) {}

        syncSlideToStorage();
        updatePresenterConsole();

        const isAnnex = slides[current].classList.contains('annex') || slides[current].dataset.annex === 'true';
        const prevArrow = document.getElementById('prevArrow');
        const nextArrow = document.getElementById('nextArrow');
        
        if (isAnnex) {
          if (navPill) navPill.style.display = 'none';
          progressFill.parentElement.style.display = 'none';
        } else {
          progressFill.parentElement.style.display = 'block';
          progressFill.style.setProperty('--nav-progress-frac', (normalSequence[current] / normalCount).toFixed(4));
          
          if (navPill) {
            navPill.style.display = 'flex';
            
            const showCounterOpt = {{ 'true' if slide_number else 'false' }};
            if (showCounterOpt && counter) {
              counter.style.display = 'flex';
              counter.textContent = normalSequence[current] + ' / ' + normalCount;
            } else if (counter) {
              counter.style.display = 'none';
            }
            
            const showArrowsOpt = {{ 'true' if nav_arrows else 'false' }};
            if (prevArrow) prevArrow.style.display = showArrowsOpt ? 'flex' : 'none';
            if (nextArrow) nextArrow.style.display = showArrowsOpt ? 'flex' : 'none';
          }
        }
        showControlsWithFade();
        
        // Update TOC highlighting
        document.querySelectorAll('.toc-item').forEach(li => li.classList.remove('active'));
        const currentSlide = slides[current];
        if (currentSlide) {
          const slideIndex = currentSlide.dataset.index;
          const activeTocItem = document.querySelector(`.toc-item[data-slide="${slideIndex}"]`);
          if (activeTocItem) {
            activeTocItem.classList.add('active');
          }
        }
      };

      if (document.startViewTransition) {
        document.startViewTransition(performGoTo);
      } else {
        performGoTo();
      }
    }

    // Sequentially moves only between NON-ANNEX slides
    function next() {
      const currentSlide = slides[current];
      if (currentSlide && (currentSlide.classList.contains('annex') || currentSlide.dataset.annex === 'true')) {
        return;
      }
      
      let nextIdx = current + 1;
      while (nextIdx < total) {
        const isAnnex = slides[nextIdx].classList.contains('annex') || slides[nextIdx].dataset.annex === 'true';
        if (!isAnnex) {
          goTo(nextIdx, 'forward');
          return;
        }
        nextIdx++;
      }
    }

    function prev() {
      const currentSlide = slides[current];
      if (currentSlide && (currentSlide.classList.contains('annex') || currentSlide.dataset.annex === 'true')) {
        return;
      }

      let prevIdx = current - 1;
      while (prevIdx >= 0) {
        const isAnnex = slides[prevIdx].classList.contains('annex') || slides[prevIdx].dataset.annex === 'true';
        if (!isAnnex) {
          goTo(prevIdx, 'backward');
          return;
        }
        prevIdx--;
      }
    }

    function toggleToc() {
      tocSidebar.classList.remove('closed-override');
      tocSidebar.classList.toggle('open');
      tocOverlay.classList.toggle('open');
    }

    function closeToc() {
      tocSidebar.classList.remove('open');
      tocOverlay.classList.remove('open');
      tocSidebar.classList.add('closed-override');
    }

    // Keyboard navigation
    document.addEventListener('keydown', function(e) {
      showControlsWithFade();
      
      // If lightbox is open, Escape should close it
      if (e.key === 'Escape') {
        const lightbox = document.getElementById('lightboxOverlay');
        if (lightbox.classList.contains('active')) {
          e.preventDefault();
          closeLightbox();
          return;
        }
      }

      // Allow keyboard navigation to run steps, but block slide transition on annex slides
      const currentSlide = slides[current];
      const isCurrentAnnex = currentSlide.classList.contains('annex') || currentSlide.dataset.annex === 'true';

      switch(e.key) {
        case 'ArrowRight': case 'ArrowDown': case ' ': case 'PageDown':
          e.preventDefault(); handleNext(); break;
        case 'ArrowLeft': case 'ArrowUp': case 'PageUp':
          e.preventDefault(); handlePrev(); break;
        case 'Home': 
          if (!isCurrentAnnex) {
            e.preventDefault(); goTo(0); 
          }
          break;
        case 'End':
          if (!isCurrentAnnex) {
            // Ir al último slide normal (no anexo)
            for (let i = total - 1; i >= 0; i--) {
              const isAnnex = slides[i].classList.contains('annex') || slides[i].dataset.annex === 'true';
              if (!isAnnex) {
                e.preventDefault();
                goTo(i);
                break;
              }
            }
          }
          break;
        case 't': case 'T': case 'Escape':
          e.preventDefault(); toggleToc(); break;
        case 'f': case 'F':
          e.preventDefault(); toggleFullscreen(); break;
        case 'l': case 'L':
          e.preventDefault();
          toggleLaserMode();
          break;
        case 'd': case 'D':
          e.preventDefault(); toggleDrawingMode(); break;
        case 'c': case 'C':
          e.preventDefault(); clearCanvas(); break;
      }
    });

    // TOC clicks
    document.querySelectorAll('.toc-item').forEach(li => {
      li.addEventListener('click', function() {
        history.push(current);
        const slideIndex = parseInt(this.dataset.slide, 10);
        if (!isNaN(slideIndex)) {
            // Find the slide in the DOM with this index
            const targetSlide = slides.find(s => parseInt(s.dataset.index, 10) === slideIndex);
            if (targetSlide) {
                goTo(slides.indexOf(targetSlide));
            }
        }
        closeToc();
      });
    });

    // TOC overlay click to close
    tocOverlay.addEventListener('click', closeToc);

    // Reset closed-override when mouse leaves the sidebar
    tocSidebar.addEventListener('mouseleave', function() {
      tocSidebar.classList.remove('closed-override');
    });

    const sidebarTrigger = document.getElementById('sidebarTrigger');
    if (sidebarTrigger) {
      sidebarTrigger.addEventListener('mouseenter', function() {
        tocSidebar.classList.remove('closed-override');
      });
    }

    // Deep links
    document.addEventListener('click', function(e) {
      const link = e.target.closest('.link-detalle, .link-anexo');
      if (link) {
        e.preventDefault();
        const target = link.dataset.target || link.getAttribute('href');
        if (target && target.startsWith('#')) {
          const targetId = target.substring(1);
          // Find slide with matching id
          for (let i = 0; i < total; i++) {
            if (slides[i].id === targetId || slides[i].dataset.id === targetId) {
              history.push(current);
              goTo(i);
              return;
            }
          }
        }
      }
    });

    // Back button (layout-scrollable)
    document.querySelectorAll('.btn-volver').forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        if (history.length > 0) goTo(history.pop());
        else prev();
      });
    });

    // Floating navigation arrows click listeners
    const prevArrow = document.getElementById('prevArrow');
    const nextArrow = document.getElementById('nextArrow');
    if (prevArrow && nextArrow) {
      prevArrow.addEventListener('click', function(e) {
        e.stopPropagation();
        handlePrev();
      });
      nextArrow.addEventListener('click', function(e) {
        e.stopPropagation();
        handleNext();
      });
    }

    // SVG Lightbox logic with pan & zoom support
    const lightbox = document.getElementById('lightboxOverlay');
    const lightboxContent = document.getElementById('lightboxContent');
    const lightboxWrapper = document.getElementById('lightboxWrapper');
    const lightboxClose = document.getElementById('lightboxClose');

    let zoom = 1;
    let panX = 0;
    let panY = 0;
    let isDragging = false;
    let startX = 0;
    let startY = 0;

    function updateTransform() {
      lightboxWrapper.style.transform = `translate(${panX}px, ${panY}px) scale(${zoom})`;
    }

    function resetZoomPan() {
      zoom = 1;
      panX = 0;
      panY = 0;
      updateTransform();
    }

    document.addEventListener('click', function(e) {
      showControlsWithFade();
      const svgEl = e.target.closest('.diagram-container svg');
      if (svgEl) {
        // Open lightbox
        const clone = svgEl.cloneNode(true);
        // Clear sizes to make it responsive inside the wrapper
        clone.removeAttribute('width');
        clone.removeAttribute('height');
        clone.style.width = '100%';
        clone.style.height = '100%';
        clone.style.maxWidth = '90vw';
        clone.style.maxHeight = '80vh';

        lightboxWrapper.innerHTML = '';
        lightboxWrapper.appendChild(clone);
        
        resetZoomPan();
        
        lightbox.style.display = 'flex';
        lightbox.offsetHeight; // trigger reflow
        lightbox.classList.add('active');
      }
    });

    function closeLightbox() {
      lightbox.classList.remove('active');
      setTimeout(() => {
        lightbox.style.display = 'none';
        lightboxWrapper.innerHTML = '';
      }, 300);
    }

    if (lightboxClose) {
      lightboxClose.addEventListener('click', closeLightbox);
    }
    if (lightbox) {
      lightbox.addEventListener('click', function(e) {
        // Close on clicking outside the wrapper or image
        if (e.target === lightbox || e.target === lightboxContent) {
          closeLightbox();
        }
      });
    }

    // Zoom & pan events
    lightboxContent.addEventListener('mousedown', function(e) {
      if (e.target.closest('#lightboxClose') || e.target.closest('.lightbox-controls')) return;
      isDragging = true;
      lightboxWrapper.style.cursor = 'grabbing';
      startX = e.clientX - panX;
      startY = e.clientY - panY;
      e.preventDefault();
    });

    document.addEventListener('mousemove', function(e) {
      if (!isDragging) return;
      panX = e.clientX - startX;
      panY = e.clientY - startY;
      lightboxWrapper.style.transition = 'none'; // disable transitions while dragging
      updateTransform();
    });

    document.addEventListener('mouseup', function() {
      if (isDragging) {
        isDragging = false;
        lightboxWrapper.style.cursor = 'grab';
        lightboxWrapper.style.transition = 'transform 0.15s cubic-bezier(0.16, 1, 0.3, 1)';
      }
    });

    lightboxContent.addEventListener('wheel', function(e) {
      e.preventDefault();
      const zoomFactor = 0.15;
      if (e.deltaY < 0) {
        zoom = Math.min(zoom * (1 + zoomFactor), 8);
      } else {
        zoom = Math.max(zoom * (1 - zoomFactor), 0.3);
      }
      lightboxWrapper.style.transition = 'transform 0.15s cubic-bezier(0.16, 1, 0.3, 1)';
      updateTransform();
    }, { passive: false });

    // Floating controls buttons
    const zoomInBtn = document.getElementById('zoomIn');
    const zoomOutBtn = document.getElementById('zoomOut');
    const zoomResetBtn = document.getElementById('zoomReset');

    if (zoomInBtn && zoomOutBtn && zoomResetBtn) {
      zoomInBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        zoom = Math.min(zoom * 1.3, 8);
        lightboxWrapper.style.transition = 'transform 0.2s cubic-bezier(0.16, 1, 0.3, 1)';
        updateTransform();
      });

      zoomOutBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        zoom = Math.max(zoom / 1.3, 0.3);
        lightboxWrapper.style.transition = 'transform 0.2s cubic-bezier(0.16, 1, 0.3, 1)';
        updateTransform();
      });

      zoomResetBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        lightboxWrapper.style.transition = 'transform 0.25s cubic-bezier(0.16, 1, 0.3, 1)';
        resetZoomPan();
      });
    }

    // Code stepping, steps list, and layer stack (clicks to advance)
    document.querySelectorAll('.code-container.stepping, .steps-list, .layer-stack').forEach(container => {
      container.addEventListener('click', function(e) {
        e.stopPropagation();
        handleNext();
      });
    });

    // Laser pointer
    document.addEventListener('mousemove', function(e) {
      showControlsWithFade();
      if (laserActive) {
        laser.style.left = e.clientX + 'px';
        laser.style.top = e.clientY + 'px';
      }
    });

    const fsBtn = document.getElementById('fsBtn');
    const SVG_MAXIMIZE = `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-svg"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"></path></svg>`;
    const SVG_MINIMIZE = `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-svg"><path d="M4 14h6v6m10-6h-6v6M4 10h6V4m10 6h-6V4"></path></svg>`;

    let lastFullscreenToggle = 0;
    function toggleFullscreen() {
      const now = Date.now();
      if (now - lastFullscreenToggle < 500) return;
      lastFullscreenToggle = now;

      const isFullscreen = !!(document.fullscreenElement || 
                              document.webkitFullscreenElement || 
                              document.mozFullScreenElement || 
                              document.msFullscreenElement ||
                              document.webkitIsFullScreen ||
                              document.mozFullScreen);

      if (!isFullscreen) {
        const docElm = document.documentElement;
        if (docElm.requestFullscreen) {
          docElm.requestFullscreen().catch(err => {
            console.error(`Error requesting fullscreen: ${err.message}`);
          });
        } else if (docElm.webkitRequestFullscreen) {
          docElm.webkitRequestFullscreen();
        } else if (docElm.mozRequestFullScreen) {
          docElm.mozRequestFullScreen();
        } else if (docElm.msRequestFullscreen) {
          docElm.msRequestFullscreen();
        }
      } else {
        if (document.exitFullscreen) {
          document.exitFullscreen();
        } else if (document.webkitExitFullscreen) {
          document.webkitExitFullscreen();
        } else if (document.mozCancelFullScreen) {
          document.mozCancelFullScreen();
        } else if (document.msExitFullscreen) {
          document.msExitFullscreen();
        }
      }
    }

    if (fsBtn) {
      fsBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        toggleFullscreen();
      });
    }

    function updateFullscreenUI() {
      const isFullscreen = !!(document.fullscreenElement || 
                              document.webkitFullscreenElement || 
                              document.mozFullScreenElement || 
                              document.msFullscreenElement ||
                              document.webkitIsFullScreen ||
                              document.mozFullScreen);
      if (fsBtn) {
        if (isFullscreen) {
          fsBtn.innerHTML = SVG_MINIMIZE;
          fsBtn.setAttribute('title', 'Salir de Pantalla Completa (F)');
          fsBtn.setAttribute('aria-label', 'Salir de Pantalla Completa');
          fsBtn.classList.add('active');
        } else {
          fsBtn.innerHTML = SVG_MAXIMIZE;
          fsBtn.setAttribute('title', 'Pantalla Completa (F)');
          fsBtn.setAttribute('aria-label', 'Pantalla Completa');
          fsBtn.classList.remove('active');
        }
      }
    }

    ['fullscreenchange', 'webkitfullscreenchange', 'mozfullscreenchange', 'MSFullscreenChange'].forEach(eventName => {
      document.addEventListener(eventName, updateFullscreenUI);
    });

    function toggleDrawingMode() {
      drawingActive = !drawingActive;
      if (drawingCanvas) {
        drawingCanvas.classList.toggle('active', drawingActive);
      }
      if (drawBtn) {
        drawBtn.classList.toggle('active', drawingActive);
      }
    }

    function clearCanvas() {
      if (canvasCtx && drawingCanvas) {
        canvasCtx.clearRect(0, 0, drawingCanvas.width, drawingCanvas.height);
        delete savedDrawings[current];
      }
    }

    function toggleLaserMode() {
      laserActive = !laserActive;
      if (laser) {
        laser.style.display = laserActive ? 'block' : 'none';
      }
      if (laserBtn) {
        laserBtn.classList.toggle('active', laserActive);
      }
    }

    if (laserBtn) {
      laserBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        toggleLaserMode();
      });
    }

    if (drawBtn) {
      drawBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        toggleDrawingMode();
      });
    }
    if (clearBtn) {
      clearBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        clearCanvas();
      });
    }

    // Drawing mouse events
    if (drawingCanvas) {
      drawingCanvas.addEventListener('mousedown', function(e) {
        if (!drawingActive) return;
        isDrawing = true;
        lastX = e.clientX;
        lastY = e.clientY;
      });
      drawingCanvas.addEventListener('mousemove', function(e) {
        if (!isDrawing || !canvasCtx) return;
        canvasCtx.beginPath();
        canvasCtx.moveTo(lastX, lastY);
        canvasCtx.lineTo(e.clientX, e.clientY);
        
        canvasCtx.strokeStyle = getComputedStyle(document.documentElement).getPropertyValue('--accent-primary') || '#C8006B';
        canvasCtx.lineWidth = 4;
        canvasCtx.lineCap = 'round';
        canvasCtx.lineJoin = 'round';
        canvasCtx.stroke();
        
        lastX = e.clientX;
        lastY = e.clientY;
      });
      drawingCanvas.addEventListener('mouseup', function() { isDrawing = false; });
      drawingCanvas.addEventListener('mouseout', function() { isDrawing = false; });

      // Touch events support for tablets/mobile
      drawingCanvas.addEventListener('touchstart', function(e) {
        if (!drawingActive || e.touches.length !== 1) return;
        isDrawing = true;
        lastX = e.touches[0].clientX;
        lastY = e.touches[0].clientY;
      });
      drawingCanvas.addEventListener('touchmove', function(e) {
        if (!isDrawing || !canvasCtx || e.touches.length !== 1) return;
        e.preventDefault();
        canvasCtx.beginPath();
        canvasCtx.moveTo(lastX, lastY);
        canvasCtx.lineTo(e.touches[0].clientX, e.touches[0].clientY);
        
        canvasCtx.strokeStyle = getComputedStyle(document.documentElement).getPropertyValue('--accent-primary') || '#C8006B';
        canvasCtx.lineWidth = 4;
        canvasCtx.lineCap = 'round';
        canvasCtx.lineJoin = 'round';
        canvasCtx.stroke();
        
        lastX = e.touches[0].clientX;
        lastY = e.touches[0].clientY;
      });
      drawingCanvas.addEventListener('touchend', function() { isDrawing = false; });
    }

    // Hotspot pin click delegation and dismissal
    document.addEventListener('click', function(e) {
      const marker = e.target.closest('.hotspots-container .pin-marker');
      if (marker) {
        e.stopPropagation();
        const pin = marker.parentElement;
        const container = pin.parentElement;
        const pins = container.querySelectorAll('.hotspot-pin');
        const isActive = pin.classList.contains('active');
        pins.forEach(p => p.classList.remove('active'));
        if (!isActive) {
          pin.classList.add('active');
        }
      } else {
        const clickedInsideTooltip = e.target.closest('.hotspots-container .pin-tooltip');
        if (!clickedInsideTooltip) {
          document.querySelectorAll('.hotspots-container .hotspot-pin.active').forEach(p => {
            p.classList.remove('active');
          });
        }
      }
    });

    /* --- Presenter Console & Sync Logic --- */
    let presenterWindow = null;
    let startTime = Date.now();
    let timerInterval = null;
    const urlParams = new URLSearchParams(window.location.search);

    function startPresenterTimer() {
      startTime = Date.now();
      if (timerInterval) clearInterval(timerInterval);
      timerInterval = setInterval(updatePresenterTimer, 1000);
      updatePresenterTimer();
    }

    function updatePresenterTimer() {
      const clockEl = document.getElementById('presenterClock');
      if (clockEl) {
        const now = new Date();
        clockEl.textContent = now.toTimeString().split(' ')[0];
      }
      
      const stopwatchEl = document.getElementById('presenterStopwatch');
      if (stopwatchEl) {
        const elapsedSecs = Math.floor((Date.now() - startTime) / 1000);
        const mins = Math.floor(elapsedSecs / 60);
        const secs = elapsedSecs % 60;
        stopwatchEl.textContent = `${String(mins).padStart(2, '0')}:${String(secs).padStart(2, '0')}`;
      }
    }

    function updatePresenterConsole() {
      if (!document.body.classList.contains('presenter-view-active')) return;
      
      const currentFrame = document.getElementById('presenterCurrentFrame');
      const nextFrame = document.getElementById('presenterNextFrame');
      const notesContent = document.getElementById('presenterSpeakerNotes');
      const slideInfo = document.getElementById('presenterSlideInfo');
      
      if (!currentFrame || !nextFrame || !notesContent || !slideInfo) return;
      
      // Clear frames
      currentFrame.innerHTML = '';
      nextFrame.innerHTML = '';
      
      // Clone current slide
      const currentSlideNode = slides[current];
      if (currentSlideNode) {
        const clonedCurrent = currentSlideNode.cloneNode(true);
        clonedCurrent.classList.remove('active');
        currentFrame.appendChild(clonedCurrent);
        
        // Dynamically scale the cloned slide to fit the frame
        const frameWidth = currentFrame.clientWidth || 340;
        const scale = frameWidth / 1280;
        clonedCurrent.style.transform = `scale(${scale})`;
        clonedCurrent.style.transformOrigin = 'top left';
        clonedCurrent.style.width = '1280px';
        clonedCurrent.style.height = '720px';
        clonedCurrent.style.position = 'absolute';
        clonedCurrent.style.top = '0';
        clonedCurrent.style.left = '0';
        
        // Speaker notes
        const notesContainer = currentSlideNode.querySelector('.speaker-notes-content');
        if (notesContainer) {
          notesContent.innerHTML = notesContainer.innerHTML;
        } else {
          const rawNotes = currentSlideNode.getAttribute('data-notes');
          notesContent.innerHTML = rawNotes ? `<p>${rawNotes}</p>` : '<p class="italic dim">Sin notas para esta diapositiva.</p>';
        }
      }
      
      // Clone next slide (non-annex)
      let nextIdx = current + 1;
      while (nextIdx < total) {
        const isAnnex = slides[nextIdx].classList.contains('annex') || slides[nextIdx].dataset.annex === 'true';
        if (!isAnnex) break;
        nextIdx++;
      }
      
      if (nextIdx < total) {
        const nextSlideNode = slides[nextIdx];
        const clonedNext = nextSlideNode.cloneNode(true);
        clonedNext.classList.remove('active');
        nextFrame.appendChild(clonedNext);
        
        const frameWidth = nextFrame.clientWidth || 340;
        const scale = frameWidth / 1280;
        clonedNext.style.transform = `scale(${scale})`;
        clonedNext.style.transformOrigin = 'top left';
        clonedNext.style.width = '1280px';
        clonedNext.style.height = '720px';
        clonedNext.style.position = 'absolute';
        clonedNext.style.top = '0';
        clonedNext.style.left = '0';
      } else {
        nextFrame.innerHTML = '<div style="display:flex;align-items:center;justify-content:center;height:100%;color:#64748b;font-weight:bold;">Fin de la presentación</div>';
      }
      
      slideInfo.textContent = `Slide ${normalSequence[current] || 1} / ${normalCount}`;
    }

    function togglePresenterMode(active) {
      if (active === undefined) {
        active = !document.body.classList.contains('presenter-view-active');
      }
      
      if (active) {
        document.body.classList.add('presenter-view-active');
        startPresenterTimer();
        setTimeout(updatePresenterConsole, 100);
      } else {
        document.body.classList.remove('presenter-view-active');
        if (timerInterval) {
          clearInterval(timerInterval);
          timerInterval = null;
        }
      }
    }

    function openPresenterConsole() {
      const presenterUrl = window.location.origin + window.location.pathname + '?presenter=true';
      presenterWindow = window.open(presenterUrl, 'presenterConsole', 'width=1200,height=800');
    }

    function syncSlideToStorage() {
      try {
        localStorage.setItem('pmd_sync_slide', current);
        localStorage.setItem('pmd_sync_timestamp', Date.now());
      } catch (e) {}
      
      if (presenterWindow && !presenterWindow.closed) {
        presenterWindow.postMessage({ type: 'pmd_sync_slide', slide: current }, '*');
      }
      if (window.opener && !window.opener.closed) {
        window.opener.postMessage({ type: 'pmd_sync_slide', slide: current }, '*');
      }
    }

    window.addEventListener('storage', function(e) {
      if (e.key === 'pmd_sync_slide') {
        const val = parseInt(e.newValue, 10);
        if (!isNaN(val) && val !== current && val >= 0 && val < total) {
          goTo(val);
        }
      }
    });

    window.addEventListener('message', function(e) {
      if (e.data && e.data.type === 'pmd_sync_slide') {
        const val = parseInt(e.data.slide, 10);
        if (!isNaN(val) && val !== current && val >= 0 && val < total) {
          goTo(val);
        }
      }
    });

    // Keyboard support for opening presenter console (P)
    document.addEventListener('keydown', function(e) {
      if ((e.key === 'p' || e.key === 'P') && !e.ctrlKey && !e.metaKey && !e.altKey) {
        e.preventDefault();
        if (urlParams.get('presenter') === 'true') {
          togglePresenterMode(false);
          window.close();
        } else {
          openPresenterConsole();
        }
      }
    });

    // Button event listeners
    const presenterBtn = document.getElementById('presenterBtn');
    if (presenterBtn) {
      presenterBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        openPresenterConsole();
      });
    }
    
    const closeConsoleBtn = document.getElementById('presenterCloseConsole');
    if (closeConsoleBtn) {
      closeConsoleBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        togglePresenterMode(false);
        window.close();
      });
    }
    
    const resetTimerBtn = document.getElementById('presenterResetTimer');
    if (resetTimerBtn) {
      resetTimerBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        startPresenterTimer();
      });
    }
    
    const presPrevBtn = document.getElementById('presenterPrevBtn');
    if (presPrevBtn) {
      presPrevBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        handlePrev();
      });
    }
    
    const presNextBtn = document.getElementById('presenterNextBtn');
    if (presNextBtn) {
      presNextBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        handleNext();
      });
    }

    if (urlParams.get('presenter') === 'true') {
      togglePresenterMode(true);
    }

    // --- Phase 3 Advanced Components & Micro-interactions ---
    function animateCounter(counter) {
      const target = parseInt(counter.getAttribute('data-target') || '0', 10);
      const duration = parseInt(counter.getAttribute('duration') || '1500', 10);
      const prefix = counter.getAttribute('prefix') || '';
      const suffix = counter.getAttribute('suffix') || '';
      const hasPlus = counter.textContent.startsWith('+');
      
      let startTimestamp = null;
      const step = (timestamp) => {
        if (!startTimestamp) startTimestamp = timestamp;
        const progress = Math.min((timestamp - startTimestamp) / duration, 1);
        const easeProgress = progress * (2 - progress); // OutQuad easing
        const currentVal = Math.floor(easeProgress * target);
        
        let displayVal = currentVal.toLocaleString();
        if (hasPlus && currentVal >= 0) {
          displayVal = '+' + displayVal;
        }
        counter.textContent = prefix + displayVal + suffix;
        
        if (progress < 1) {
          window.requestAnimationFrame(step);
        } else {
          let finalVal = target.toLocaleString();
          if (hasPlus && target >= 0) {
            finalVal = '+' + finalVal;
          }
          counter.textContent = prefix + finalVal + suffix;
        }
      };
      window.requestAnimationFrame(step);
    }

    function buildChart(canvas) {
      if (typeof Chart === 'undefined') {
        setTimeout(() => buildChart(canvas), 100);
        return;
      }
      const rawConfig = canvas.getAttribute('data-chart-config');
      if (!rawConfig) return;
      try {
        const config = JSON.parse(rawConfig);
        const ctx = canvas.getContext('2d');
        const style = getComputedStyle(document.documentElement);
        const primaryColor = style.getPropertyValue('--accent-primary').trim() || '#00c86b';
        const textMain = style.getPropertyValue('--text-main').trim() || '#333333';
        const textMuted = style.getPropertyValue('--text-muted').trim() || '#71717a';
        const gridColor = style.getPropertyValue('--border-subtle').trim() || 'rgba(255,255,255,0.05)';
        
        const getAlphaColor = (colorStr, opacity) => {
          const tempCtx = document.createElement('canvas').getContext('2d');
          tempCtx.fillStyle = colorStr;
          const resolved = tempCtx.fillStyle;
          if (resolved.startsWith('rgba')) {
            return resolved.replace(/[^,)]+(?=\))/, opacity);
          } else if (resolved.startsWith('rgb')) {
            return resolved.replace('rgb', 'rgba').replace(')', `, ${opacity})`);
          } else if (resolved.startsWith('#')) {
            let hex = resolved.slice(1);
            if (hex.length === 3) hex = hex.split('').map(c => c + c).join('');
            const r = parseInt(hex.substring(0, 2), 16);
            const g = parseInt(hex.substring(2, 4), 16);
            const b = parseInt(hex.substring(4, 6), 16);
            return `rgba(${r}, ${g}, ${b}, ${opacity})`;
          }
          return colorStr;
        };

        const rawColors = config.colors && config.colors.length > 0 ? config.colors : [];
        let colors;
        if (rawColors.length > 0) {
          colors = rawColors.map(c => {
            const cssVar = `--color-${c}`;
            const val = style.getPropertyValue(cssVar).trim();
            if (val) return val;
            const alt = style.getPropertyValue(`--accent-${c}`).trim();
            if (alt) return alt;
            return c;
          });
        } else {
          colors = [
            primaryColor,
            style.getPropertyValue('--accent-secondary').trim() || '#8b5cf6',
            style.getPropertyValue('--accent-blue').trim() || '#06b6d4',
            style.getPropertyValue('--accent-red').trim() || '#ef4444',
            style.getPropertyValue('--accent-yellow').trim() || '#f59e0b',
            style.getPropertyValue('--accent-green').trim() || '#10b981',
            style.getPropertyValue('--accent-copper').trim() || '#8b5cf6'
          ];
        }
        
        const datasets = [{
          label: 'Datos',
          data: config.data,
          backgroundColor: config.type === 'line' ? 'rgba(0, 0, 0, 0)' : colors,
          borderColor: config.type === 'line' ? primaryColor : colors,
          borderWidth: 2,
          hoverOffset: 4
        }];
        
        if (config.type === 'line') {
          datasets[0].fill = true;
          const gradient = ctx.createLinearGradient(0, 0, 0, canvas.height || 300);
          gradient.addColorStop(0, getAlphaColor(primaryColor, 0.26));
          gradient.addColorStop(1, getAlphaColor(primaryColor, 0));
          datasets[0].backgroundColor = gradient;
          datasets[0].tension = 0.4;
        }
        
        canvas.chartInstance = new Chart(ctx, {
          type: config.type,
          data: {
            labels: config.labels,
            datasets: datasets
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
plugins: {
               legend: {
                 display: ['pie', 'doughnut', 'polarArea', 'radar'].includes(config.type),
                 labels: {
                   color: textMain,
                   font: {
                     family: style.getPropertyValue('--font-family-base') || 'system-ui',
                     size: 14
                   }
                 }
               },
               tooltip: {
                 padding: 12,
                 cornerRadius: 8,
                 backgroundColor: style.getPropertyValue('--bg-chrome') || '#1f2937',
                 titleColor: textMain,
                 bodyColor: textMain,
                 borderColor: style.getPropertyValue('--border-subtle') || '#374151',
                 borderWidth: 1,
                 titleFont: { size: 14 },
                 bodyFont: { size: 13 }
               }
             },
             scales: ['pie', 'doughnut', 'polarArea', 'radar'].includes(config.type) ? {} : {
               x: {
                 grid: { color: gridColor },
                 ticks: { color: textMuted, font: { size: 13 } }
               },
               y: {
                 grid: { color: gridColor },
                 ticks: { color: textMuted, font: { size: 13 } }
               }
             }
          }
        });
      } catch (e) {
        console.error("Error initializing Chart.js:", e);
      }
    }

    function onSlideActive(slideIdx) {
      const slide = slides[slideIdx];
      if (!slide) return;
      
      // Initialize/animate counters
      slide.querySelectorAll('.animated-counter').forEach(counter => {
        animateCounter(counter);
      });
      
      // Initialize charts
      slide.querySelectorAll('canvas.presentmd-chart').forEach(canvas => {
        if (canvas.chartInstance) {
          canvas.chartInstance.destroy();
        }
        buildChart(canvas);
      });

      // Initialize/animate progress rings
      slide.querySelectorAll('.progress-ring-fill').forEach(ring => {
        const val = parseFloat(ring.getAttribute('data-value') || '0');
        const circ = parseFloat(ring.getAttribute('data-circumference') || '0');
        const targetOffset = circ - (val / 100) * circ;
        ring.style.strokeDashoffset = circ; // Reset
        ring.getBoundingClientRect(); // Reflow
        ring.style.strokeDashoffset = targetOffset;
      });

      // Initialize typewriter animations
      slide.querySelectorAll('.typewriter-container').forEach(container => {
        const textEl = container.querySelector('.typewriter-text');
        if (!textEl) return;
        if (!container.hasAttribute('data-original-text')) {
          container.setAttribute('data-original-text', textEl.textContent);
        }
        const fullText = container.getAttribute('data-original-text');
        const speed = parseInt(container.getAttribute('data-speed') || '50', 10);
        const delay = parseInt(container.getAttribute('data-delay') || '200', 10);
        
        textEl.textContent = '';
        container.style.opacity = '1';
        
        if (container.typewriterInterval) {
          clearInterval(container.typewriterInterval);
        }
        if (container.typewriterTimeout) {
          clearTimeout(container.typewriterTimeout);
        }
        
        container.typewriterTimeout = setTimeout(() => {
          let currentIdx = 0;
          container.typewriterInterval = setInterval(() => {
            textEl.textContent += fullText[currentIdx];
            currentIdx++;
            if (currentIdx >= fullText.length) {
              clearInterval(container.typewriterInterval);
              container.typewriterInterval = null;
            }
          }, speed);
        }, delay);
      });

      // Initialize fade-stagger containers
      slide.querySelectorAll('.fade-stagger-container').forEach(container => {
        const children = Array.from(container.children);
        const delay = parseInt(container.getAttribute('data-delay') || '100', 10);
        const speed = parseInt(container.getAttribute('data-speed') || '300', 10);
        
        container.style.setProperty('--stagger-speed', `${speed}ms`);
        children.forEach((child, index) => {
          child.style.transitionDelay = `${index * delay}ms`;
        });
        container.getBoundingClientRect(); // Reflow
        container.classList.add('active');
      });

      // Reset animations on all other slides to allow re-triggering
      slides.forEach((s, idx) => {
        if (idx !== slideIdx) {
          // Reset progress rings
          s.querySelectorAll('.progress-ring-fill').forEach(ring => {
            const circ = parseFloat(ring.getAttribute('data-circumference') || '0');
            ring.style.strokeDashoffset = circ;
          });

          // Reset typewriter text
          s.querySelectorAll('.typewriter-container').forEach(c => {
            if (c.typewriterInterval) {
              clearInterval(c.typewriterInterval);
              c.typewriterInterval = null;
            }
            if (c.typewriterTimeout) {
              clearTimeout(c.typewriterTimeout);
              c.typewriterTimeout = null;
            }
            const orig = c.getAttribute('data-original-text');
            if (orig) {
              const textEl = c.querySelector('.typewriter-text');
              if (textEl) textEl.textContent = orig;
            }
            c.style.opacity = '0';
          });

          // Reset fade-stagger
          s.querySelectorAll('.fade-stagger-container').forEach(c => {
            c.classList.remove('active');
            Array.from(c.children).forEach(child => {
              child.style.transitionDelay = '';
            });
          });
        }
      });
    }

    function initializeTabs() {
      document.addEventListener('click', (e) => {
        const tabBtn = e.target.closest('.tab-button');
        if (!tabBtn) return;
        
        const container = tabBtn.closest('.tabs-container');
        if (!container) return;
        
        const tabButtons = container.querySelectorAll('.tab-button');
        const tabPanels = container.querySelectorAll('.tab-panel');
        
        tabButtons.forEach(btn => {
          btn.classList.remove('active');
          btn.setAttribute('aria-selected', 'false');
          btn.setAttribute('tabindex', '-1');
        });
        
        tabPanels.forEach(panel => {
          panel.classList.remove('active');
          panel.setAttribute('hidden', 'true');
        });
        
        tabBtn.classList.add('active');
        tabBtn.setAttribute('aria-selected', 'true');
        tabBtn.setAttribute('tabindex', '0');
        
        const controlsId = tabBtn.getAttribute('aria-controls');
        if (controlsId) {
          const activePanel = document.getElementById(controlsId);
          if (activePanel) {
            activePanel.classList.add('active');
            activePanel.removeAttribute('hidden');
          }
        }
      });
      
      document.addEventListener('keydown', (e) => {
        const tabBtn = e.target.closest('.tab-button');
        if (!tabBtn) return;
        
        const container = tabBtn.closest('.tabs-container');
        if (!container) return;
        
        const tabButtons = Array.from(container.querySelectorAll('.tab-button'));
        const index = tabButtons.indexOf(tabBtn);
        
        let newIndex = -1;
        if (e.key === 'ArrowRight') {
          newIndex = (index + 1) % tabButtons.length;
        } else if (e.key === 'ArrowLeft') {
          newIndex = (index - 1 + tabButtons.length) % tabButtons.length;
        } else if (e.key === 'Home') {
          newIndex = 0;
        } else if (e.key === 'End') {
          newIndex = tabButtons.length - 1;
        }
        
        if (newIndex !== -1) {
          e.preventDefault();
          tabButtons[newIndex].focus();
          tabButtons[newIndex].click();
        }
      });
    }

    initializeTabs();

    // Init
    window.addEventListener('resize', scaleSlides);
    scaleSlides();
    
    // Start at first normal slide or saved slide from hot-reload/refresh
    let startIdx = 0;
    const savedSlide = sessionStorage.getItem('pmd_current_slide');
    if (savedSlide !== null && parseInt(savedSlide) < total) {
      startIdx = parseInt(savedSlide);
    } else {
      while (startIdx < total) {
        const isAnnex = slides[startIdx].classList.contains('annex') || slides[startIdx].dataset.annex === 'true';
        if (!isAnnex) break;
        startIdx++;
      }
    }
    goTo(startIdx);

    {% if live_reload %}
    // Live Reload via Server-Sent Events (SSE)
    window.addEventListener('beforeunload', () => {
      sessionStorage.setItem('pmd_current_slide', current);
    });

    const evtSource = new EventSource('/events');
    evtSource.onmessage = (e) => {
      if (e.data === 'reload') {
        sessionStorage.setItem('pmd_current_slide', current);
        location.reload();
      }
    };
     {% endif %}
  </script>
  {% if has_mermaid %}
  <script type="module">
    (async () => {
      let mermaid;
      try {
        const module = await import('./mermaid.esm.min.mjs');
        mermaid = module.default;
      } catch (err) {
        console.warn("No se pudo cargar mermaid.esm.min.mjs localmente, intentando CDN...");
        try {
          const module = await import('https://cdn.jsdelivr.net/npm/mermaid@10.9.1/dist/mermaid.esm.min.mjs');
          mermaid = module.default;
        } catch (cdnErr) {
          console.error("No se pudo cargar Mermaid desde CDN tampoco:", cdnErr);
          return;
        }
      }

      if (!mermaid) return;

      try {
        const computedStyles = getComputedStyle(document.documentElement);
        const getVarColor = (name, fallback) => {
          const val = computedStyles.getPropertyValue(name).trim();
          return val || fallback;
        };

        mermaid.initialize({
          startOnLoad: false,
          theme: 'base',
          logLevel: 'error',
          securityLevel: 'loose',
          themeVariables: {
            background: getVarColor('--bg-canvas', '#ffffff'),
            primaryColor: getVarColor('--accent-primary', '#00c86b'),
            primaryTextColor: getVarColor('--text-main', '#333333'),
            primaryBorderColor: getVarColor('--text-muted', '#71717a'),
            lineColor: getVarColor('--text-muted', '#71717a'),
            secondaryColor: getVarColor('--bg-chrome', '#f4f4f5'),
            tertiaryColor: getVarColor('--bg-chrome', '#f4f4f5'),
          }
        });

        const elements = document.querySelectorAll(".mermaid");
        for (const el of elements) {
          try {
            const code = el.textContent.trim();
            const id = "mermaid-" + Math.random().toString(36).substring(2, 9);
            const { svg } = await mermaid.render(id, code);
            
            const container = el.parentElement;
            if (container && container.classList.contains('diagram-container')) {
              container.innerHTML = svg;
            } else {
              el.outerHTML = svg;
            }
          } catch (renderErr) {
            console.error("Error al renderizar diagrama Mermaid:", renderErr);
            const code = el.textContent;
            const container = el.parentElement;
            const fallbackHTML = `
              <div class="diagram-container fallback mermaid-failed">
                <div class="diagram-fallback-header" style="background-color: var(--accent-red, #ef4444); color: white;">
                  <span class="diagram-icon">⚠️</span>
                  <span class="diagram-title">Error en Diagrama Mermaid</span>
                  <span class="diagram-badge">FALLO RENDER</span>
                </div>
                <pre class="diagram-fallback-code"><code>${code}</code></pre>
                <div class="diagram-fallback-footer">
                  No se pudo renderizar el diagrama debido a un error de sintaxis o de inicialización.
                </div>
              </div>
            `;
            if (container && container.classList.contains('diagram-container')) {
              container.outerHTML = fallbackHTML;
            } else {
              el.outerHTML = fallbackHTML;
            }
          }
        }
      } catch (initErr) {
        console.error("Error al inicializar Mermaid:", initErr);
      }
    })();
  </script>
  {% endif %}
  {% if has_charts %}
  <script src="./chart.umd.min.js"></script>
  <script>
    if (typeof Chart === 'undefined') {
      const script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/npm/chart.js';
      document.head.appendChild(script);
    }
  </script>
  {% endif %}
