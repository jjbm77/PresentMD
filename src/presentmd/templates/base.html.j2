  /* --- PmdProcessFlow --- */
  class PmdProcessFlow extends PmdSmartArtBase {
    static get viewBox() { return '0 0 1400 600'; }
    static get itemSelector() { return '.pmd-process-flow-item'; }

    renderGeometry(svg, items, isSteps) {
      const N = items.length;
      const w = 1400 / N;
      const yMidBar = 300;
      const hBar = 46;
      const yTopBar = yMidBar - hBar / 2;
      const yBottomBar = yMidBar + hBar / 2;
      const delta = Math.min(16, w * 0.15);
      const cardW = 300;
      const cardH = 120;

       for (let i = 0; i < N; i++) {
         const item = items[i];
         const color = item.getAttribute('data-color') || '1';
         const isEven = i % 2 === 0;
        const xLeft = i * w;
        const xRight = (i + 1) * w;

        let dChevron;
        if (i === 0) {
          dChevron = `M ${xLeft},${yTopBar} L ${xRight},${yTopBar} L ${xRight + delta},${yMidBar} L ${xRight},${yBottomBar} L ${xLeft},${yBottomBar} Z`;
        } else {
          dChevron = `M ${xLeft},${yTopBar} L ${xRight},${yTopBar} L ${xRight + delta},${yMidBar} L ${xRight},${yBottomBar} L ${xLeft},${yBottomBar} L ${xLeft + delta},${yMidBar} Z`;
        }

        const xChevronCenter = i * w + w / 2 + delta / 2;
        const xCard = xChevronCenter - cardW / 2;
        const yCard = isEven ? 50 : 400;
        const xStart = xChevronCenter;
        const yStart = isEven ? yTopBar : yBottomBar;
        const yCardBound = isEven ? yCard + cardH : yCard;
        const yMidConnector = (yStart + yCardBound) / 2;
        const xOffset = Math.min(25, w * 0.08);

        let dConn;
        const dy = yCardBound - yStart;
        if (Math.abs(dy) < 10) {
          dConn = `M ${xStart},${yStart} L ${xStart},${yCardBound}`;
        } else {
          dConn = `M ${xStart},${yStart} L ${xStart},${yMidConnector} L ${xStart + xOffset},${yMidConnector} L ${xStart + xOffset},${yCardBound}`;
        }

        const g = this._createGroup(svg, isSteps, color);

        const pathChevron = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        pathChevron.setAttribute('d', dChevron);
        pathChevron.setAttribute('class', 'smartart-chevron-path');
        g.appendChild(pathChevron);

        const pathConn = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        pathConn.setAttribute('d', dConn);
        pathConn.setAttribute('class', 'smartart-connector-line');
        g.appendChild(pathConn);

        const dotStart = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        dotStart.setAttribute('cx', String(xStart));
        dotStart.setAttribute('cy', String(yStart));
        dotStart.setAttribute('r', '3.5');
        dotStart.setAttribute('class', 'smartart-connector-dot');
        g.appendChild(dotStart);

        const dotEnd = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        dotEnd.setAttribute('cx', String(xStart + xOffset));
        dotEnd.setAttribute('cy', String(yCardBound));
        dotEnd.setAttribute('r', '3.5');
        dotEnd.setAttribute('class', 'smartart-connector-dot');
        g.appendChild(dotEnd);

        const iconEl = item.querySelector('.pmd-process-flow-icon');
        const textEl = item.querySelector('.pmd-process-flow-text');
        let labelVal = '';
        if (iconEl && iconEl.textContent.trim()) {
          labelVal = iconEl.textContent.trim();
        } else if (textEl && textEl.textContent.trim()) {
          labelVal = textEl.textContent.trim();
        } else {
          labelVal = (i + 1).toString();
        }
        const svgText = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        svgText.setAttribute('x', String(xChevronCenter));
        svgText.setAttribute('y', String(yMidBar));
        svgText.setAttribute('class', 'smartart-chevron-text');
        svgText.setAttribute('dominant-baseline', 'central');
        svgText.setAttribute('text-anchor', 'middle');
        svgText.textContent = labelVal;
        g.appendChild(svgText);

        const label = item.querySelector('.pmd-process-flow-label')?.textContent || '';
        const desc = item.querySelector('.pmd-process-flow-desc')?.textContent || '';
        this._createCard(g, xCard, yCard, cardW, cardH, label, desc);
      }
    }
  }
  customElements.define('pmd-process-flow', PmdProcessFlow);

  /* --- PmdRadialProcess --- */
  class PmdRadialProcess extends PmdSmartArtBase {
    static get viewBox() { return '-650 -350 1300 700'; }
    static get itemSelector() { return '.pmd-radial-process-item'; }

    renderGeometry(svg, items, isSteps) {
      const centerTitle = this.getAttribute('center-title') || '';
      const innerRadius = 170;
      const outerRadius = 250;
      const elbowRadius = 290;
      const cardXEnd = 330;
      const cardW = 300;
      const cardH = 120;

      const centerCircle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      centerCircle.setAttribute('cx', '0');
      centerCircle.setAttribute('cy', '0');
      centerCircle.setAttribute('r', String(innerRadius));
      centerCircle.setAttribute('class', 'smartart-center-circle');
      svg.appendChild(centerCircle);

      const foCenter = document.createElementNS('http://www.w3.org/2000/svg', 'foreignObject');
      foCenter.setAttribute('x', '-140');
      foCenter.setAttribute('y', '-140');
      foCenter.setAttribute('width', '280');
      foCenter.setAttribute('height', '280');
      foCenter.setAttribute('class', 'smartart-center-fo');
      const foContent = document.createElement('div');
      foContent.innerHTML = `<span class="smartart-center-text">${centerTitle}</span>`;
      foCenter.appendChild(foContent);
      svg.appendChild(foCenter);

      const N = items.length;
      const anglePerSegment = 360 / N;

       for (let i = 0; i < N; i++) {
         const item = items[i];
         const color = item.getAttribute('data-color') || '1';
 
         const startAngle = -90 + i * anglePerSegment;
        const endAngle = -90 + (i + 1) * anglePerSegment;
        const midAngle = startAngle + anglePerSegment / 2;
        const midRad = (midAngle * Math.PI) / 180;
        const cosA = Math.cos(midRad);
        const sinA = Math.sin(midRad);
        const xOuter = cosA * outerRadius;
        const yOuter = sinA * outerRadius;
        const startRad = (startAngle * Math.PI) / 180;
        const endRad = (endAngle * Math.PI) / 180;
        const x1 = Math.cos(startRad) * outerRadius;
        const y1 = Math.sin(startRad) * outerRadius;
        const x2 = Math.cos(endRad) * outerRadius;
        const y2 = Math.sin(endRad) * outerRadius;
        const ix1 = Math.cos(startRad) * innerRadius;
        const iy1 = Math.sin(startRad) * innerRadius;
        const ix2 = Math.cos(endRad) * innerRadius;
        const iy2 = Math.sin(endRad) * innerRadius;
        const largeArc = anglePerSegment > 180 ? 1 : 0;

        const g = this._createGroup(svg, isSteps, color);

        const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        path.setAttribute('d', [
          `M ${x1},${y1}`,
          `A ${outerRadius},${outerRadius} 0 ${largeArc},1 ${x2},${y2}`,
          `L ${ix2},${iy2}`,
          `A ${innerRadius},${innerRadius} 0 ${largeArc},0 ${ix1},${iy1}`,
          'Z'
        ].join(' '));
        path.setAttribute('class', 'smartart-radial-arc');
        g.appendChild(path);

        const isRight = cosA >= 0;
        const elbowX = cosA * elbowRadius;
        const elbowY = sinA * elbowRadius;
        const endX = isRight ? cardXEnd : -cardXEnd;
        const endY = elbowY;

        const poly = document.createElementNS('http://www.w3.org/2000/svg', 'polyline');
        poly.setAttribute('points', `${xOuter},${yOuter} ${elbowX},${elbowY} ${endX},${endY}`);
        poly.setAttribute('class', 'smartart-connector-line');
        g.appendChild(poly);

        const xCard = isRight ? endX : endX - cardW;
        const yCard = endY - cardH / 2;
        const label = item.querySelector('.pmd-radial-process-label')?.textContent || '';
        const desc = item.querySelector('.pmd-radial-process-desc')?.textContent || '';
        this._createCard(g, xCard, yCard, cardW, cardH, label, desc);
      }
    }
  }
  customElements.define('pmd-radial-process', PmdRadialProcess);

