<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  {% if og_description %}
  <meta name="description" content="{{ og_description | escape }}">
  <meta property="og:title" content="{{ title | escape }}">
  <meta property="og:description" content="{{ og_description | escape }}">
  <meta property="twitter:card" content="summary_large_image">
  {% endif %}
  <style>
/* PURE STRUCTURAL CSS - FRAMEWORK LEVEL */
body { margin: 0; padding: 0; overflow: hidden; background: #000; }
.presentation-container {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
}
.slide {
  position: absolute;
  top: 0; left: 0; width: 100vw; height: 100vh;
  display: none;
  opacity: 0;
  overflow: hidden;
  transition: opacity 0.4s ease, transform 0.4s ease;
  box-sizing: border-box;
  isolation: isolate !important;
}
.slide.active {
  display: flex;
  opacity: 1;
  z-index: 10;
}
.toc-sidebar {
  position: fixed;
  top: 0;
  left: 0;
  width: 300px;
  height: 100vh;
  z-index: 2000;
  transform: translateX(-100%);
  transition: transform 0.3s ease;
  overflow-y: auto;
}
.toc-sidebar.active {
  transform: translateX(0);
}
.sidebar-trigger {
  position: fixed;
  top: 0; left: 0; width: 20px; height: 100vh;
  z-index: 1900;
}
.sidebar-trigger:hover + .toc-sidebar, .toc-sidebar:hover { transform: translateX(0) !important; }
.toc-sidebar.closed-override { transform: translateX(-100%) !important; }

html.view-transitions-supported .slide {
  transition: none !important;
}

/* Framework Layout Guardrails */
.layout-title { display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; position: relative; }
.layout-standard { display: flex; flex-direction: column; box-sizing: border-box; }
.layout-standard .slide-body { flex: 1; min-height: 0; display: flex; flex-direction: column; }
.layout-scrollable .slide-body { overflow-y: auto; }
.layout-split-comparison .slide-body { display: grid; grid-template-columns: 1fr 1fr; height: 100%; }

/* Grid Layout Component Styles */
.grid-container {
  display: flex;
  gap: 24px;
  width: 100%;
  box-sizing: border-box;
  align-items: stretch;
}

/* Attribute-to-Style Declarations for strict decoupling */
[data-clip-path] { clip-path: var(--clip-path) !important; }
[data-margin-left] { margin-left: var(--margin-left) !important; }
[data-z-index] { z-index: var(--z-index) !important; }
[data-left] { left: var(--left-pos) !important; }
[data-top] { top: var(--top-pos) !important; }
[data-ring-size] { width: var(--ring-size) !important; height: var(--ring-size) !important; }
[data-col-width] { width: var(--col-width) !important; }
[data-col-frac] { flex: var(--col-frac) !important; }
[data-bar-height] { height: var(--bar-height) !important; }

/* Global Text & Layout Guardrails to prevent structural breakages */
.slide *, .slide-body * {
  max-width: 100%;
  word-wrap: break-word;
  overflow-wrap: break-word;
}
.grid-container, .grid-column, .process-card, .callout-box, .diagram-container, .pyramid-container {
  max-width: 100%;
  box-sizing: border-box;
}
.grid-column {
  flex: var(--col-frac, 1);
  width: var(--col-width, auto);
  min-width: 0;
  box-sizing: border-box;
  flex-shrink: 1;
}

{{ font_face | safe }}
{{ theme_css | safe }}

/* Framework Guardrails for Controls */
.slide-counter { font-size: 13px !important; }
.nav-arrow-btn, .fs-btn { font-size: 13px !important; }
.fab-trigger { font-size: 13px !important; }

.slide-counter { transition: opacity 0.5s ease; opacity: 1; }
.slide-counter.fade-out { opacity: 0 !important; }
:root {
  --ease-out-expo: cubic-bezier(0.19, 1, 0.22, 1);
  --ease-in-out-quart: cubic-bezier(0.76, 0, 0.24, 1);
  --duration-fast: 150ms;
  --duration-normal: 300ms;
  --duration-slow: 600ms;
  --stagger-step: 80ms;
}

{% if logo %}
:root {
  --logo-url: url("{{ logo }}");
}
.footer-logo {
  display: inline-block;
  height: 36px;
  width: 160px;
  background-image: var(--logo-url);
  background-size: contain;
  background-repeat: no-repeat;
  background-position: right center;
}
.title-logo {
  display: inline-block;
  height: 64px;
  width: 240px;
  background-image: var(--logo-url);
  background-size: contain;
  background-repeat: no-repeat;
  background-position: left center;
}
.title-logo-container.logo-bottom .title-logo {
  background-position: center;
}
{% else %}
.footer-logo, .title-logo { display: none; }
{% endif %}
.slide-footer { display: flex; justify-content: space-between; align-items: center; padding: 0 40px 12px; pointer-events: none; }
.footer-text { flex-grow: 1; text-align: left; }
.title-logo-container { margin-bottom: 20px; text-align: left; }
.title-logo-container.logo-bottom { text-align: center; }
.title-footer { position: absolute; bottom: 40px; left: 80px; right: 80px; text-align: left; }
.nav-pill-container {
  position: fixed;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 8px;
  z-index: 1000;
  transition: opacity 0.4s ease, transform 0.4s ease;
  opacity: 1;
}
.nav-pill-container.fade-out {
  opacity: 0 !important;
  pointer-events: none;
}
.fab-container {
  position: fixed;
  bottom: 20px;
  right: 24px;
  display: flex;
  flex-direction: column-reverse;
  align-items: center;
  gap: 10px;
  z-index: 1000;
  transition: opacity 0.4s ease, transform 0.4s ease;
  opacity: 1;
}
.fab-container.fade-out {
  opacity: 0 !important;
  pointer-events: none;
}
.fab-menu {
  display: flex;
  flex-direction: column-reverse;
  align-items: center;
  gap: 10px;
  opacity: 0;
  visibility: hidden;
  transform: translateY(15px) scale(0.95);
  transition: opacity 0.2s ease, transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), visibility 0.2s;
  pointer-events: none;
}
.fab-container.active .fab-menu {
  opacity: 1;
  visibility: visible;
  transform: translateY(0) scale(1);
  pointer-events: auto;
}

/* Stagger transition delay for menu items when expanding */
.fab-container.active .fab-item:nth-child(1) { transition-delay: 0.04s; }
.fab-container.active .fab-item:nth-child(2) { transition-delay: 0.08s; }
.fab-container.active .fab-item:nth-child(3) { transition-delay: 0.12s; }
.fab-container.active .fab-item:nth-child(4) { transition-delay: 0.16s; }
.fab-container.active .fab-item:nth-child(5) { transition-delay: 0.2s; }

.nav-arrow-btn, .fs-btn {
  width: 38px;
  height: 38px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s, color 0.2s, transform 0.2s, border-color 0.2s, box-shadow 0.2s;
  outline: none;
  padding: 0;
  margin: 0;
}
.nav-arrow-btn:active, .fs-btn:active {
  transform: scale(0.95);
}
.icon-svg {
  width: 18px;
  height: 18px;
  stroke-width: 2px;
}
.slide-counter {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 38px;
  padding: 0 10px;
  box-sizing: border-box;
  margin: 0;
  z-index: auto;
}
.fab-trigger-icon {
  transition: transform 0.2s ease;
}
.fab-container.active .fab-trigger-icon {
  transform: rotate(90deg);
}
.lightbox-overlay { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 2000; display: none; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.3s ease; }
.lightbox-overlay.active { display: flex; opacity: 1; }
.lightbox-content { max-width: 90%; max-height: 90%; display: flex; align-items: center; justify-content: center; }
#lightboxWrapper {
  background: var(--bg-canvas, #ffffff);
  border: 1px solid var(--border-color, rgba(128, 128, 128, 0.15));
  border-radius: var(--border-radius-md, 16px);
  padding: 32px;
  box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.4), 0 10px 10px -5px rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}
.lightbox-content svg { width: auto; height: auto; max-width: 90vw; max-height: 80vh; object-fit: contain; cursor: grab; }
.lightbox-content svg:active { cursor: grabbing; }
.lightbox-controls { position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%); display: flex; gap: 12px; padding: 8px 16px; z-index: 2010; }
.lightbox-btn { width: 36px; height: 36px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s, transform 0.1s, color 0.2s; background: transparent; border: none; }
.lightbox-btn:active { transform: scale(0.95); }
.lightbox-close { position: absolute; top: 20px; right: 20px; cursor: pointer; z-index: 2010; background: none; border: none; }
.diagram-container svg { cursor: zoom-in; transition: transform 0.2s ease; }
.diagram-container svg .edgePath .path,
#lightboxWrapper svg .edgePath .path,
.diagram-container svg .edgePaths .edgePath,
#lightboxWrapper svg .edgePaths .edgePath,
.diagram-container svg path.path,
#lightboxWrapper svg path.path,
.diagram-container svg .flowchart-link,
#lightboxWrapper svg .flowchart-link,
.diagram-container svg .connection,
#lightboxWrapper svg .connection,
.diagram-container svg g.edgePaths path,
#lightboxWrapper svg g.edgePaths path,
.diagram-container svg g.edge-paths path,
#lightboxWrapper svg g.edge-paths path,
.diagram-container svg g.edges path,
#lightboxWrapper svg g.edges path {
  stroke: var(--text-muted, #71717a) !important;
  stroke-width: 1.5px !important;
}
.diagram-container svg .arrowheadPath,
#lightboxWrapper svg .arrowheadPath,
.diagram-container svg marker path,
#lightboxWrapper svg marker path {
  fill: var(--text-muted, #71717a) !important;
  stroke: var(--text-muted, #71717a) !important;
}
@keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
@keyframes fadeInLeft { from { opacity: 0; transform: translateX(-20px); } to { opacity: 1; transform: translateX(0); } }

.has-animations .slide.active .kpi-card {
  animation: var(--animation-kpi-enter, fadeInUp var(--duration-slow, 0.6s) var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)) both);
}
.has-animations .slide.active .kpi-card:nth-child(1) { animation-delay: calc(var(--stagger-step, 100ms) * 1); }
.has-animations .slide.active .kpi-card:nth-child(2) { animation-delay: calc(var(--stagger-step, 100ms) * 2); }
.has-animations .slide.active .kpi-card:nth-child(3) { animation-delay: calc(var(--stagger-step, 100ms) * 3); }
.has-animations .slide.active .kpi-card:nth-child(4) { animation-delay: calc(var(--stagger-step, 100ms) * 4); }
.has-animations .slide.active .kpi-card:nth-child(5) { animation-delay: calc(var(--stagger-step, 100ms) * 5); }
.has-animations .slide.active .kpi-card:nth-child(6) { animation-delay: calc(var(--stagger-step, 100ms) * 6); }
.has-animations .slide.active .kpi-card:nth-child(7) { animation-delay: calc(var(--stagger-step, 100ms) * 7); }
.has-animations .slide.active .kpi-card:nth-child(8) { animation-delay: calc(var(--stagger-step, 100ms) * 8); }

.has-animations .slide.active .timeline-phase {
  animation: var(--animation-timeline-enter, fadeInUp var(--duration-slow, 0.6s) var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)) both);
}
.has-animations .slide.active .timeline-phase:nth-child(1) { animation-delay: calc(var(--stagger-step, 100ms) * 1); }
.has-animations .slide.active .timeline-phase:nth-child(2) { animation-delay: calc(var(--stagger-step, 100ms) * 2); }
.has-animations .slide.active .timeline-phase:nth-child(3) { animation-delay: calc(var(--stagger-step, 100ms) * 3); }
.has-animations .slide.active .timeline-phase:nth-child(4) { animation-delay: calc(var(--stagger-step, 100ms) * 4); }
.has-animations .slide.active .timeline-phase:nth-child(5) { animation-delay: calc(var(--stagger-step, 100ms) * 5); }
.has-animations .slide.active .timeline-phase:nth-child(6) { animation-delay: calc(var(--stagger-step, 100ms) * 6); }
.has-animations .slide.active .timeline-phase:nth-child(7) { animation-delay: calc(var(--stagger-step, 100ms) * 7); }
.has-animations .slide.active .timeline-phase:nth-child(8) { animation-delay: calc(var(--stagger-step, 100ms) * 8); }

.has-animations .slide.active .info-box {
  animation: var(--animation-infobox-enter, fadeInLeft var(--duration-normal, 0.5s) var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)) both);
}
.has-animations .slide.active .info-box:nth-child(1) { animation-delay: calc(var(--stagger-step-tight, 50ms) * 1); }
.has-animations .slide.active .info-box:nth-child(2) { animation-delay: calc(var(--stagger-step-tight, 50ms) * 2); }
.has-animations .slide.active .info-box:nth-child(3) { animation-delay: calc(var(--stagger-step-tight, 50ms) * 3); }
.has-animations .slide.active .info-box:nth-child(4) { animation-delay: calc(var(--stagger-step-tight, 50ms) * 4); }
.has-animations .slide.active .info-box:nth-child(5) { animation-delay: calc(var(--stagger-step-tight, 50ms) * 5); }
.has-animations .slide.active .info-box:nth-child(6) { animation-delay: calc(var(--stagger-step-tight, 50ms) * 6); }
.has-animations .slide.active .info-box:nth-child(7) { animation-delay: calc(var(--stagger-step-tight, 50ms) * 7); }
.has-animations .slide.active .info-box:nth-child(8) { animation-delay: calc(var(--stagger-step-tight, 50ms) * 8); }

.has-animations .slide.active .feature-card {
  animation: var(--animation-feature-enter, fadeInUp var(--duration-slow, 0.6s) var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)) both);
}
.has-animations .slide.active .feature-card:nth-child(1) { animation-delay: calc(var(--stagger-step, 100ms) * 1); }
.has-animations .slide.active .feature-card:nth-child(2) { animation-delay: calc(var(--stagger-step, 100ms) * 2); }
.has-animations .slide.active .feature-card:nth-child(3) { animation-delay: calc(var(--stagger-step, 100ms) * 3); }
.has-animations .slide.active .feature-card:nth-child(4) { animation-delay: calc(var(--stagger-step, 100ms) * 4); }
.has-animations .slide.active .feature-card:nth-child(5) { animation-delay: calc(var(--stagger-step, 100ms) * 5); }
.has-animations .slide.active .feature-card:nth-child(6) { animation-delay: calc(var(--stagger-step, 100ms) * 6); }
.has-animations .slide.active .feature-card:nth-child(7) { animation-delay: calc(var(--stagger-step, 100ms) * 7); }
.has-animations .slide.active .feature-card:nth-child(8) { animation-delay: calc(var(--stagger-step, 100ms) * 8); }

.bar-fill {
  width: var(--target-width, 100%);
}
.has-animations .bar-fill {
  width: 100%;
  transform: scaleX(0);
  transform-origin: left;
  transition: transform var(--duration-slow, 1.2s) var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1));
}
.has-animations .slide.active .bar-fill {
  transform: scaleX(var(--target-width-frac, 0));
}

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-delay: 0s !important;
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-delay: 0s !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
}
.diagram-container.fallback { overflow: hidden; margin: 15px 0; }
.diagram-fallback-header { padding: 10px 15px; display: flex; justify-content: space-between; align-items: center; }
.diagram-fallback-header .diagram-title { flex-grow: 1; margin-left: 10px; }
.diagram-fallback-code { margin: 0; padding: 15px; max-height: 250px; overflow-y: auto; text-align: left; }
.diagram-fallback-footer { padding: 8px 15px; text-align: left; }
.sidebar-trigger { position: fixed; top: 0; left: 0; width: 18px; height: 100vh; z-index: 998; background: transparent; }
.sidebar-trigger:hover + .toc-sidebar, .toc-sidebar:hover { left: 0 !important; }
.toc-separator { padding: 12px; pointer-events: none; margin-top: 12px; }
.toc-annex { display: flex; align-items: center; gap: 8px; }
.slide-bg-overlay {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  background-size: cover; background-position: center;
  z-index: -1; pointer-events: none;
}

/* --- Spotlight Overlay --- */
.spotlight-overlay {
  position: fixed;
  top: 0; left: 0; width: 100vw; height: 100vh;
  background: rgba(0, 0, 0, 0.7);
  z-index: 3000;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.4s ease;
  --spotlight-x: 50vw;
  --spotlight-y: 50vh;
  --spotlight-radius: 100px;
  mask-image: radial-gradient(circle at var(--spotlight-x) var(--spotlight-y), transparent var(--spotlight-radius), black calc(var(--spotlight-radius) + 20px));
  -webkit-mask-image: radial-gradient(circle at var(--spotlight-x) var(--spotlight-y), transparent var(--spotlight-radius), black calc(var(--spotlight-radius) + 20px));
}
.spotlight-overlay.active { opacity: 1; pointer-events: none !important; }
.spotlight-tooltip {
  position: fixed;
  z-index: 3010;
  display: none;
  pointer-events: auto !important;
}
.spotlight-active-target {
  position: relative !important;
  z-index: 3005 !important;
}

/* Hotspots Global Layout & Stacking Context Guardrails */
.hotspots-container {
  overflow: visible !important;
}
.hotspot-pin.active {
  z-index: 10000 !important;
}
.pin-tooltip {
  width: max-content !important;
  min-width: 200px !important;
  max-width: 300px !important;
  white-space: normal !important;
  word-wrap: break-word !important;
  pointer-events: auto !important;
}

/* Tooltip High-Contrast Typography Overrides */
.pin-tooltip, .spotlight-tooltip,
.pin-tooltip p, .spotlight-tooltip p,
.pin-tooltip h1, .pin-tooltip h2, .pin-tooltip h3, .pin-tooltip h4,
.spotlight-tooltip h1, .spotlight-tooltip h2, .spotlight-tooltip h3, .spotlight-tooltip h4 {
  color: #ffffff !important;
}

/* Prevent FOUC for step-animated elements */
[data-step]:not(.step-visible) {
  opacity: 0 !important;
  pointer-events: none !important;
}
.bar-chart-column[data-step]:not(.step-visible) {
  opacity: 0 !important;
  transform: translateY(20px) !important;
  pointer-events: none !important;
}
.bar-chart-column[data-step]:not(.step-visible) .chart-bar-fill {
  height: 0 !important;
}

/* Spotlight Target Containers & Auto-Generated Targets */
.spotlight-targets-container {
  display: flex;
  flex-wrap: wrap;
  gap: 1.5rem;
  margin: 1.5rem 0;
  align-items: flex-start;
}
.spotlight-target-box {
  padding: 1.25rem 2rem;
  background: var(--border-color, rgba(128, 128, 128, 0.08));
  border: 1px solid var(--border-color, rgba(128, 128, 128, 0.15));
  border-radius: 8px;
  color: var(--text-main, #ffffff);
  font-weight: 500;
  display: inline-block;
  cursor: zoom-in;
  transition: all 0.3s ease;
  backdrop-filter: blur(8px);
}
.spotlight-target-box:hover {
  background: var(--border-color, rgba(128, 128, 128, 0.12));
  transform: translateY(-2px);
}
.spotlight-target-text {
  font-size: 1.1rem;
  color: var(--text-muted, #cccccc);
  font-weight: normal;
  display: inline-block;
  cursor: zoom-in;
  border-bottom: 1px dashed var(--text-muted, rgba(255, 255, 255, 0.4));
  padding-bottom: 2px;
  transition: all 0.3s ease;
}
.spotlight-target-text:hover {
  color: var(--accent-primary, #ffffff);
  border-bottom-color: var(--accent-primary, #ffffff);
}

/* --- Progress Bar --- */
.nav-progress {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100vw;
  height: 4px;
  z-index: 1000;
  pointer-events: none;
}
.nav-progress-fill {
  height: 100%;
  width: 100%;
  transform: scaleX(var(--nav-progress-frac, 0));
  transform-origin: left;
  transition: transform 0.3s ease;
}

/* --- Presenter Console Styles --- */
.presenter-console-container {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background-color: #0f172a;
  color: #f1f5f9;
  font-family: system-ui, -apple-system, sans-serif;
  grid-template-columns: 380px 1fr;
  grid-template-rows: 1fr 60px;
  grid-template-areas:
    "left right"
    "bottom bottom";
  z-index: 10000;
  box-sizing: border-box;
}

body.presenter-view-active {
  overflow: hidden;
  background-color: #0f172a !important;
}

body.presenter-view-active .presenter-console-container {
  display: grid;
}

/* Hide all normal slideshow elements in presenter view */
body.presenter-view-active .presentation-container,
body.presenter-view-active .toc-sidebar,
body.presenter-view-active .sidebar-trigger,
body.presenter-view-active .toc-overlay,
body.presenter-view-active .bottom-controls,
body.presenter-view-active .nav-progress,
body.presenter-view-active .drawing-canvas,
body.presenter-view-active .laser-pointer,
body.presenter-view-active .spotlight-overlay,
body.presenter-view-active .spotlight-tooltip {
  display: none !important;
}

.presenter-left-panel {
  grid-area: left;
  background-color: #1e293b;
  border-right: 1px solid #334155;
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 20px;
  box-sizing: border-box;
}

.presenter-right-panel {
  grid-area: right;
  padding: 20px;
  display: grid;
  grid-template-rows: 100px 1fr;
  gap: 20px;
  box-sizing: border-box;
  overflow: hidden;
}

.presenter-preview-box {
  background-color: #0f172a;
  border: 1px solid #334155;
  border-radius: 8px;
  padding: 10px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  box-sizing: border-box;
}

.presenter-preview-label {
  font-size: 0.75rem;
  font-weight: 700;
  color: #94a3b8;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.slide-frame {
  position: relative;
  width: 100%;
  aspect-ratio: 16/9;
  background-color: #000;
  border-radius: 4px;
  overflow: hidden;
  border: 1px solid #475569;
}

/* Inside the slide preview we want to show the cloned slide */
.slide-frame .slide {
  display: flex !important;
  opacity: 1 !important;
  pointer-events: none !important;
  box-shadow: none !important;
}

.presenter-timer-box {
  background-color: #1e293b;
  border: 1px solid #334155;
  border-radius: 8px;
  padding: 15px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
}

.timer-segment {
  display: flex;
  flex-direction: column;
}

.timer-label {
  font-size: 0.7rem;
  font-weight: 700;
  color: #94a3b8;
  text-transform: uppercase;
  margin-bottom: 2px;
}

.timer-value {
  font-size: 1.8rem;
  font-family: monospace;
  font-weight: bold;
  color: #38bdf8;
}

.timer-reset-btn {
  background-color: #334155;
  border: 1px solid #475569;
  color: #f1f5f9;
  border-radius: 4px;
  padding: 8px 12px;
  font-size: 0.85rem;
  cursor: pointer;
  transition: background 0.15s;
}

.timer-reset-btn:hover {
  background-color: #475569;
}

.presenter-notes-box {
  background-color: #1e293b;
  border: 1px solid #334155;
  border-radius: 8px;
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  overflow: hidden;
  box-sizing: border-box;
}

.presenter-notes-content {
  font-size: 1.15rem;
  line-height: 1.6;
  color: #e2e8f0;
  overflow-y: auto;
  flex: 1;
  white-space: pre-wrap;
  padding-right: 5px;
}

.presenter-notes-content p {
  margin-top: 0;
  margin-bottom: 1em;
}

.presenter-bottom-bar {
  grid-area: bottom;
  background-color: #0f172a;
  border-top: 1px solid #334155;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30px;
  box-sizing: border-box;
}

.presenter-slide-info {
  font-size: 1rem;
  font-weight: 600;
  color: #94a3b8;
}

.presenter-nav-buttons {
  display: flex;
  gap: 15px;
}

.presenter-nav-btn {
  background-color: #0284c7;
  border: none;
  color: #fff;
  font-weight: 600;
  font-size: 1rem;
  padding: 10px 20px;
  border-radius: 6px;
  cursor: pointer;
  transition: background 0.15s;
}

.presenter-nav-btn:hover {
  background-color: #0369a1;
}

.presenter-close-btn {
  background-color: #ef4444;
  border: none;
  color: #fff;
  font-weight: 600;
  font-size: 0.9rem;
  padding: 8px 16px;
  border-radius: 4px;
  cursor: pointer;
  transition: background 0.15s;
}

/* Tabs interactive switcher */
.tabs-container {
  display: flex;
  flex-direction: column;
  width: 100%;
  margin: 20px 0;
  background: var(--bg-chrome, rgba(255, 255, 255, 0.05));
  border: 1px solid var(--border-subtle, rgba(255, 255, 255, 0.1));
  border-radius: var(--border-radius-md, 12px);
  padding: 16px;
  box-sizing: border-box;
}
.tabs-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  border-bottom: 2px solid var(--border-subtle, rgba(255, 255, 255, 0.1));
  padding-bottom: 12px;
  margin-bottom: 16px;
}
.tab-button {
  background: transparent;
  border: none;
  color: var(--text-muted, #71717a);
  padding: 8px 16px;
  font-family: var(--font-family-base, system-ui);
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  border-radius: var(--border-radius-sm, 6px);
  transition: all 0.2s ease;
  outline: none;
}
.tab-button:hover {
  background: var(--bg-hover, rgba(255, 255, 255, 0.08));
  color: var(--text-main, #ffffff);
}
.tab-button.active {
  background: var(--accent-primary, #00c86b);
  color: #000000;
}
.tab-panel {
  display: none;
  width: 100%;
  animation: fadeIn 0.3s ease;
}
.tab-panel.active {
  display: block;
}

/* Custom Tab variants */
.tabs-container[data-variant="solid-accent"] {
  background: var(--bg-surface, rgba(255, 255, 255, 0.03));
  border: 1px solid var(--border-subtle, rgba(255, 255, 255, 0.1));
}
.tabs-container[data-variant="solid-accent"] .tab-button {
  background: transparent;
  color: var(--text-muted, #a1a1aa);
  border: 1px solid transparent;
}
.tabs-container[data-variant="solid-accent"] .tab-button:hover {
  background: rgba(255, 255, 255, 0.05);
  color: var(--text-main, #ffffff);
}
.tabs-container[data-variant="solid-accent"] .tab-button.active {
  background: var(--accent-primary, #00c86b);
  color: #000000;
  border-color: var(--accent-primary, #00c86b);
}

/* Semantic sizes for components (typewriter and alert) */
[data-size="sm"] {
  font-size: clamp(0.75rem, 0.65rem + 0.5vw, 0.9rem) !important;
}
[data-size="md"] {
  font-size: clamp(0.9rem, 0.8rem + 0.5vw, 1.1rem) !important;
}
[data-size="lg"] {
  font-size: clamp(1.2rem, 1rem + 1vw, 1.6rem) !important;
}
[data-size="xl"] {
  font-size: clamp(1.6rem, 1.3rem + 1.5vw, 2.2rem) !important;
}

/* Specific size adjustments for alert text */
.alert-box[data-size="sm"] .alert-title { font-size: 1rem !important; }
.alert-box[data-size="sm"] .alert-body { font-size: 0.8rem !important; }
.alert-box[data-size="md"] .alert-title { font-size: 1.15rem !important; }
.alert-box[data-size="md"] .alert-body { font-size: 0.95rem !important; }
.alert-box[data-size="lg"] .alert-title { font-size: 1.4rem !important; }
.alert-box[data-size="lg"] .alert-body { font-size: 1.2rem !important; }
.alert-box[data-size="xl"] .alert-title { font-size: 1.8rem !important; }
.alert-box[data-size="xl"] .alert-body { font-size: 1.5rem !important; }

/* Semantic colors mapping to theme variables */
/* --- Universal Design Token Color Mapping --- */
[data-color="1"], .c-1 { --ui-color: var(--color-1); --ui-contrast: var(--color-1-contrast); }
[data-color="2"], .c-2 { --ui-color: var(--color-2); --ui-contrast: var(--color-2-contrast); }
[data-color="3"], .c-3 { --ui-color: var(--color-3); --ui-contrast: var(--color-3-contrast); }
[data-color="4"], .c-4 { --ui-color: var(--color-4); --ui-contrast: var(--color-4-contrast); }
[data-color="5"], .c-5 { --ui-color: var(--color-5); --ui-contrast: var(--color-5-contrast); }
[data-color="6"], .c-6 { --ui-color: var(--color-6); --ui-contrast: var(--color-6-contrast); }
:where([data-color]) { --ui-color: var(--color-1); --ui-contrast: var(--color-1-contrast); }

/* --- Universal Component Color Consumption --- */
.alert-box { border-left-color: var(--ui-color); background: color-mix(in srgb, var(--ui-color) 8%, transparent); }
.typewriter-container .typewriter-text,
.typewriter-container .typewriter-cursor { color: var(--ui-color); }
.badge { color: var(--ui-color); border: 1px solid var(--ui-color); background: color-mix(in srgb, var(--ui-color) 15%, transparent); }
.b { color: var(--ui-color); }
.progress-ring-fill { stroke: var(--ui-color, var(--accent-primary)); }
.progress-ring-fill[data-color] { stroke: var(--ui-color); }
.callout-box { border-left-color: var(--ui-color); background: color-mix(in srgb, var(--ui-color) 8%, transparent); }
.card-box { border-top: 2px solid var(--ui-color); box-shadow: 0 0 15px color-mix(in srgb, var(--ui-color) 5%, transparent); }
.feature-card { border-bottom: 3px solid var(--ui-color); }
.feature-card:hover { border-color: var(--ui-color); }
.kpi-card .kpi-value { color: var(--ui-color); text-shadow: 0 0 10px color-mix(in srgb, var(--ui-color) 30%, transparent); }
.chart-bar-fill { background: var(--ui-color); box-shadow: 0 0 8px var(--ui-color); }
[data-color] { --segment-color: var(--ui-color); }

/* Accessibility screen-readers only utility */
.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

/* Stepping system base overrides to prevent auto-animation conflicts */
.step-hidden {
  animation: none !important;
  opacity: 0 !important;
  pointer-events: none !important;
}
.step-visible {
  opacity: 1 !important;
  pointer-events: auto !important;
  animation-delay: 0s !important;
}

/* Bar Chart Column height fallback for non-step mode */
.bar-chart-column:not(.step-hidden) .chart-bar-fill {
  height: var(--bar-height) !important;
}

/* Default light text color for dark code blocks to prevent dark-theme text inherits */
.code-container {
  color: #FAFAFA !important;
}
.code-container pre, .code-container code {
  color: inherit !important;
}

/* --- Pyramid Component --- */
/* --- Unified SmartArt Component Styles --- */
pmd-radial-process, pmd-pyramid, pmd-process-flow {
  display: flex;
  flex: 1;
  width: 100%;
  height: 100%;
  min-height: 65vh;
  align-items: center;
  justify-content: center;
}
.smartart-svg {
  width: 100%;
  height: 100%;
  max-width: 100%;
}
.smartart-svg-group {
  opacity: 0;
  transition: opacity 0.35s ease;
}
.smartart-svg-group.svg-step-visible {
  opacity: 1;
}

/* --- Shape-specific paths --- */
.smartart-pyramid-left {
  fill: var(--segment-color, var(--accent-primary, #00c86b));
  opacity: 0.95;
  filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.15));
}
.smartart-pyramid-right {
  fill: var(--segment-color, var(--accent-primary, #00c86b));
  filter: brightness(0.82) drop-shadow(0 2px 4px rgba(0, 0, 0, 0.15));
  opacity: 0.95;
}
.smartart-chevron-path {
  fill: var(--segment-color, var(--accent-primary, #00c86b));
  opacity: 0.9;
  filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.15));
}
.smartart-radial-arc {
  fill: var(--segment-color, var(--accent-primary));
  stroke: var(--segment-color, var(--accent-primary));
  stroke-width: 0.5;
}

/* --- Connector lines & dots (solid, dog-leg style) --- */
.smartart-connector-line {
  fill: none;
  stroke: var(--segment-color, var(--accent-primary));
  stroke-width: 1.5;
  stroke-linejoin: round;
  stroke-linecap: round;
}
.smartart-connector-dot {
  fill: var(--segment-color, var(--accent-primary));
  stroke: var(--bg-main, #ffffff);
  stroke-width: 1.5;
}
.smartart-connector-dot-end {
  fill: var(--border-subtle, var(--text-muted, #71717a));
}

/* --- Text inside shapes --- */
.smartart-segment-text {
  font-family: var(--font-family-base, system-ui);
  font-size: 14px;
  font-weight: bold;
  fill: #ffffff;
  text-shadow: 0 1px 2px rgba(0,0,0,0.6);
  pointer-events: none;
}
.smartart-chevron-text {
  font-family: var(--font-family-base, system-ui);
  font-size: 14px;
  font-weight: bold;
  fill: #ffffff;
  text-shadow: 0 1px 2px rgba(0,0,0,0.6);
  pointer-events: none;
}

/* --- Card container (foreignObject wrapper) --- */
.smartart-card-fo {
  pointer-events: none;
  overflow: visible !important;
}
.smartart-card-fo > .smartart-card-container {
  pointer-events: auto;
  background: var(--bg-chrome, rgba(255,255,255,0.05));
  border: 1px solid var(--segment-color, var(--accent-primary));
  border-radius: 10px;
  padding: 12px 14px;
  font-family: var(--font-body, system-ui);
  font-size: 18px;
  line-height: 1.4;
  color: var(--text-main);
  box-sizing: border-box;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  backdrop-filter: blur(8px);
  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease;
}
.smartart-card-fo > .smartart-card-container:hover {
  transform: translateY(-5px);
  box-shadow: 0 6px 16px rgba(0,0,0,0.2);
}
.smartart-card-label {
  font-weight: 700;
  color: var(--segment-color, var(--accent-primary));
  font-size: 26px;
  margin-bottom: 6px;
}
.smartart-card-desc {
  color: var(--text-muted, #a1a1aa);
  font-size: 20px;
  line-height: 1.4;
}

/* --- Radial center --- */
.smartart-center-circle {
  fill: var(--bg-canvas);
  stroke: var(--border-color);
  stroke-width: 1.5;
}
.smartart-center-fo {
  pointer-events: none;
}
.smartart-center-fo > div {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.smartart-center-text {
  font-family: var(--font-body, system-ui);
  font-size: 38px;
  font-weight: 700;
  color: var(--text-main, #ffffff);
  text-transform: uppercase;
  text-align: center;
  line-height: 1.3;
  padding: 4px;
  word-break: break-word;
}

/* --- Hide original HTML items (they are stepped via MutationObserver) --- */
.pmd-pyramid-icon, .pmd-pyramid-text,
.pmd-process-flow-icon, .pmd-process-flow-text {
  display: none !important;
}
.chart-container {
  position: relative;
  width: 100%;
  height: 100%;
  max-width: 800px;
  max-height: 450px;
  flex: 1;
}

/* Inline Animated Counter styling */
.animated-counter-container {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 1.5rem;
  background: var(--bg-card, rgba(255, 255, 255, 0.03));
  border: 1px solid var(--border-subtle, rgba(255, 255, 255, 0.08));
  border-radius: 16px;
  box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.2);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  min-width: 180px;
  margin: 0.5rem;
  box-sizing: border-box;
}
.animated-counter {
  font-variant-numeric: tabular-nums;
  font-weight: 700;
  color: var(--accent-primary, #00c86b);
  transition: color 0.3s ease;
  font-size: inherit;
  line-height: inherit;
  margin: 0;
  display: inline;
}
.animated-counter-container .animated-counter {
  display: inline-block;
  font-size: 3.5rem;
  line-height: 1;
  background: linear-gradient(135deg, var(--accent-primary, #00c86b), var(--accent-secondary, #3b82f6));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 0.5rem;
  font-weight: 800;
}
.animated-counter-title {
  font-size: 0.95rem;
  color: var(--text-muted, #71717a);
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

/* Progress Ring Component styling */
.progress-ring-wrapper {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 1.5rem;
  background: var(--card-bg, var(--bg-chrome, rgba(255, 255, 255, 0.03)));
  border: 1px solid var(--card-border, var(--border-color, rgba(255, 255, 255, 0.08)));
  border-radius: 16px;
  box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.2);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  margin: 0.5rem;
  box-sizing: border-box;
}
.progress-ring-container {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}
.progress-ring-container svg {
  display: block;
}
.progress-ring-bg {
  stroke: var(--border-color, rgba(128, 128, 128, 0.2));
}
.progress-ring-fill {
  stroke: var(--ui-color, var(--accent-primary, #00c86b));
  stroke-linecap: round;
  transition: stroke-dashoffset 1.5s cubic-bezier(0.16, 1, 0.3, 1);
}

.progress-ring-percentage {
  position: absolute;
  font-size: 1.75rem;
  font-weight: 800;
  color: var(--text-main, #ffffff);
}
.progress-ring-title {
  margin-top: 1rem;
  font-size: 0.95rem;
  color: var(--text-muted, #71717a);
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

/* Typewriter Component styling */
.typewriter-container {
  display: inline-block;
  font-family: var(--font-family-mono, monospace);
  font-size: 1.25rem;
  color: var(--accent-primary, #00c86b);
  line-height: 1.6;
}
.typewriter-cursor {
  font-weight: bold;
  animation: typewriter-blink 0.8s step-end infinite;
  color: var(--accent-primary, #00c86b);
}
@keyframes typewriter-blink {
  from, to { color: transparent }
  50% { color: var(--accent-primary, #00c86b) }
}

/* Fade Stagger Component styling */
.fade-stagger-container > * {
  opacity: 1;
  transform: none;
  transition: opacity var(--stagger-speed, 300ms) ease, transform var(--stagger-speed, 300ms) ease;
}
.has-animations .slide:not(.active) .fade-stagger-container > *,
.has-animations .fade-stagger-container:not(.active) > * {
  opacity: 0;
  transform: translateY(15px);
}

/* Callout Component styling */
.callout-box {
  display: flex;
  flex-direction: column;
  margin: 1.5rem 0;
  padding: 1.25rem 1.5rem;
  border-radius: 12px;
  border-left: 5px solid var(--accent-primary, #3b82f6);
  background: var(--bg-card, rgba(255, 255, 255, 0.03));
  box-shadow: 0 4px 24px 0 rgba(0, 0, 0, 0.1);
  text-align: left;
}
.callout-box.type-1 {
  border-left-color: var(--color-1);
  background: color-mix(in srgb, var(--color-1) 8%, transparent);
}
.callout-box.type-2 {
  border-left-color: var(--color-2);
  background: color-mix(in srgb, var(--color-2) 8%, transparent);
}
.callout-box.type-3 {
  border-left-color: var(--color-3);
  background: color-mix(in srgb, var(--color-3) 8%, transparent);
}
.callout-box.type-4 {
  border-left-color: var(--color-4);
  background: color-mix(in srgb, var(--color-4) 8%, transparent);
}
.callout-box.type-5 {
  border-left-color: var(--color-5);
  background: color-mix(in srgb, var(--color-5) 8%, transparent);
}
.callout-box.type-6 {
  border-left-color: var(--color-6);
  background: color-mix(in srgb, var(--color-6) 8%, transparent);
}
.callout-header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-weight: 700;
  font-size: 1.1rem;
  color: var(--text-main, #ffffff);
  margin-bottom: 0.5rem;
}
.callout-box.collapsible .callout-header {
  cursor: pointer;
  user-select: none;
  list-style: none; /* Hide default summary marker */
}
.callout-box.collapsible .callout-header::-webkit-details-marker {
  display: none; /* Hide default summary marker on Safari */
}
.callout-chevron {
  margin-left: auto;
  font-size: 0.8rem;
  transition: transform 0.2s ease;
  color: var(--text-muted, #71717a);
}
.callout-box[open] .callout-chevron {
  transform: rotate(180deg);
}
.callout-content {
  color: var(--text-main, #e4e4e7);
  font-size: 1rem;
  line-height: 1.6;
}
.callout-content > *:first-child {
  margin-top: 0;
}
.callout-content > *:last-child {
  margin-bottom: 0;
}

@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

/* Staggered Reveals for generic list elements & cards */
.has-animations .slide.active .steps-list li:not(.step-hidden),
.has-animations .slide.active .process-step:not(.step-hidden),
.has-animations .slide.active .pyramid-level:not(.step-hidden),
.has-animations .slide.active .tab-panel > *:not(.step-hidden) {
  animation: fadeInUp var(--duration-normal, 0.5s) var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)) both;
}
.has-animations .slide.active .steps-list li:nth-child(1),
.has-animations .slide.active .process-step:nth-child(1),
.has-animations .slide.active .pyramid-level:nth-child(1) { animation-delay: calc(var(--stagger-step, 100ms) * 1); }
.has-animations .slide.active .steps-list li:nth-child(2),
.has-animations .slide.active .process-step:nth-child(2),
.has-animations .slide.active .pyramid-level:nth-child(2) { animation-delay: calc(var(--stagger-step, 100ms) * 2); }
.has-animations .slide.active .steps-list li:nth-child(3),
.has-animations .slide.active .process-step:nth-child(3),
.has-animations .slide.active .pyramid-level:nth-child(3) { animation-delay: calc(var(--stagger-step, 100ms) * 3); }
.has-animations .slide.active .steps-list li:nth-child(4),
.has-animations .slide.active .process-step:nth-child(4),
.has-animations .slide.active .pyramid-level:nth-child(4) { animation-delay: calc(var(--stagger-step, 100ms) * 4); }
.has-animations .slide.active .steps-list li:nth-child(5),
.has-animations .slide.active .process-step:nth-child(5),
.has-animations .slide.active .pyramid-level:nth-child(5) { animation-delay: calc(var(--stagger-step, 100ms) * 5); }
.has-animations .slide.active .steps-list li:nth-child(6),
.has-animations .slide.active .process-step:nth-child(6),
.has-animations .slide.active .pyramid-level:nth-child(6) { animation-delay: calc(var(--stagger-step, 100ms) * 6); }

/* --- Premium Tables (Design Token driven) --- */
.pmd-table-wrapper {
  width: 100%;
  overflow-x: auto;
  margin: 1rem 0;
  font-family: var(--font-body, system-ui);
}
.pmd-table-wrapper > table {
  width: 100%;
  border-collapse: collapse;
  font-size: 14px;
  line-height: 1.5;
  color: var(--text-main, #ffffff);
  background: var(--bg-canvas, #000);
  border-radius: 8px;
  overflow: hidden;
}
.pmd-table-wrapper caption {
  font-size: 18px;
  font-weight: 700;
  text-align: left;
  padding: 12px 14px;
  background: var(--bg-chrome, rgba(255,255,255,0.05));
  border-bottom: 1px solid var(--border-color, rgba(255,255,255,0.08));
  caption-side: top;
}
.pmd-table-wrapper th,
.pmd-table-wrapper td {
  padding: 10px 14px;
  text-align: left;
  border-bottom: 1px solid var(--border-color, rgba(255,255,255,0.06));
}
.pmd-table-wrapper th {
  font-weight: 600;
  white-space: nowrap;
}

/* variant="ribbon" — hide thead, first td of each row is a colored ribbon */
.pmd-table-wrapper[data-variant="ribbon"] thead { display: none; }
.pmd-table-wrapper[data-variant="ribbon"] tbody tr:first-child td:first-child {
  background: var(--tc-1, var(--color-1));
  color: var(--tc-text-1, var(--color-1-contrast));
  clip-path: polygon(100% 0, 100% 50%, 100% 100%, 0% 100%, 15px 50%, 0% 0%);
  padding-left: 24px;
  font-weight: 700;
}
.pmd-table-wrapper[data-variant="ribbon"] tbody tr:nth-child(2) td:first-child {
  background: var(--tc-2, var(--color-2));
  color: var(--tc-text-2, var(--color-2-contrast));
  clip-path: polygon(100% 0, 100% 50%, 100% 100%, 0% 100%, 15px 50%, 0% 0%);
  padding-left: 24px;
  font-weight: 700;
}
.pmd-table-wrapper[data-variant="ribbon"] tbody tr:nth-child(3) td:first-child {
  background: var(--tc-3, var(--color-3));
  color: var(--tc-text-3, var(--color-3-contrast));
  clip-path: polygon(100% 0, 100% 50%, 100% 100%, 0% 100%, 15px 50%, 0% 0%);
  padding-left: 24px;
  font-weight: 700;
}
.pmd-table-wrapper[data-variant="ribbon"] tbody tr:nth-child(4) td:first-child {
  background: var(--tc-4, var(--color-4));
  color: var(--tc-text-4, var(--color-4-contrast));
  clip-path: polygon(100% 0, 100% 50%, 100% 100%, 0% 100%, 15px 50%, 0% 0%);
  padding-left: 24px;
  font-weight: 700;
}
.pmd-table-wrapper[data-variant="ribbon"] tbody tr:nth-child(5) td:first-child {
  background: var(--tc-5, var(--color-5));
  color: var(--tc-text-5, var(--color-5-contrast));
  clip-path: polygon(100% 0, 100% 50%, 100% 100%, 0% 100%, 15px 50%, 0% 0%);
  padding-left: 24px;
  font-weight: 700;
}
.pmd-table-wrapper[data-variant="ribbon"] tbody tr:nth-child(6) td:first-child {
  background: var(--tc-6, var(--color-6));
  color: var(--tc-text-6, var(--color-6-contrast));
  clip-path: polygon(100% 0, 100% 50%, 100% 100%, 0% 100%, 15px 50%, 0% 0%);
  padding-left: 24px;
  font-weight: 700;
}

/* variant="colored-cols" — each th gets its column color */
.pmd-table-wrapper[data-variant="colored-cols"] th:nth-child(1) {
  background: var(--tc-1, var(--color-1));
  color: var(--tc-text-1, var(--color-1-contrast));
}
.pmd-table-wrapper[data-variant="colored-cols"] th:nth-child(2) {
  background: var(--tc-2, var(--color-2));
  color: var(--tc-text-2, var(--color-2-contrast));
}
.pmd-table-wrapper[data-variant="colored-cols"] th:nth-child(3) {
  background: var(--tc-3, var(--color-3));
  color: var(--tc-text-3, var(--color-3-contrast));
}
.pmd-table-wrapper[data-variant="colored-cols"] th:nth-child(4) {
  background: var(--tc-4, var(--color-4));
  color: var(--tc-text-4, var(--color-4-contrast));
}
.pmd-table-wrapper[data-variant="colored-cols"] th:nth-child(5) {
  background: var(--tc-5, var(--color-5));
  color: var(--tc-text-5, var(--color-5-contrast));
}
.pmd-table-wrapper[data-variant="colored-cols"] th:nth-child(6) {
  background: var(--tc-6, var(--color-6));
  color: var(--tc-text-6, var(--color-6-contrast));
}

/* variant="angled" — same as colored-cols but th has diagonal clip + extra padding */
.pmd-table-wrapper[data-variant="angled"] th:nth-child(1) {
  background: var(--tc-1, var(--color-1));
  color: var(--tc-text-1, var(--color-1-contrast));
  clip-path: polygon(0 0, calc(100% - 15px) 0, 100% 100%, 0 100%);
  padding-right: 28px;
}
.pmd-table-wrapper[data-variant="angled"] th:nth-child(2) {
  background: var(--tc-2, var(--color-2));
  color: var(--tc-text-2, var(--color-2-contrast));
  clip-path: polygon(0 0, calc(100% - 15px) 0, 100% 100%, 0 100%);
  padding-right: 28px;
}
.pmd-table-wrapper[data-variant="angled"] th:nth-child(3) {
  background: var(--tc-3, var(--color-3));
  color: var(--tc-text-3, var(--color-3-contrast));
  clip-path: polygon(0 0, calc(100% - 15px) 0, 100% 100%, 0 100%);
  padding-right: 28px;
}
.pmd-table-wrapper[data-variant="angled"] th:nth-child(4) {
  background: var(--tc-4, var(--color-4));
  color: var(--tc-text-4, var(--color-4-contrast));
  clip-path: polygon(0 0, calc(100% - 15px) 0, 100% 100%, 0 100%);
  padding-right: 28px;
}
.pmd-table-wrapper[data-variant="angled"] th:nth-child(5) {
  background: var(--tc-5, var(--color-5));
  color: var(--tc-text-5, var(--color-5-contrast));
  clip-path: polygon(0 0, calc(100% - 15px) 0, 100% 100%, 0 100%);
  padding-right: 28px;
}
.pmd-table-wrapper[data-variant="angled"] th:nth-child(6) {
  background: var(--tc-6, var(--color-6));
  color: var(--tc-text-6, var(--color-6-contrast));
  clip-path: polygon(0 0, calc(100% - 15px) 0, 100% 100%, 0 100%);
  padding-right: 28px;
}

/* variant="corporate" — caption gets primary color, no multi-column palette */
.pmd-table-wrapper[data-variant="corporate"] caption {
  color: var(--color-1, var(--accent-primary));
  border-bottom: 2px solid var(--color-1, var(--accent-primary));
}
.pmd-table-wrapper[data-variant="corporate"] th {
  background: var(--bg-chrome, rgba(255,255,255,0.04));
  color: var(--text-main, #ffffff);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  font-size: 12px;
}

/* total-row — last tr in tbody gets neutral bg + bold */
.pmd-table-wrapper[data-total-row="true"] tbody tr:last-child {
  background: var(--card-bg, rgba(255,255,255,0.04));
  font-weight: 700;
}
.pmd-table-wrapper[data-total-row="true"] tbody tr:last-child td {
  border-bottom: none;
}

/* hover effect on data rows */
.pmd-table-wrapper tbody tr:hover {
  background: rgba(255,255,255,0.03);
}
.pmd-table-wrapper[data-variant="ribbon"] tbody tr:hover td:first-child {
  filter: brightness(1.15);
}

@media print {
  @page {
    size: 1280px 720px;
    margin: 0;
  }
  
  * {
    -webkit-print-color-adjust: exact !important;
    print-color-adjust: exact !important;
  }
  
  .presentation-container { position: static !important; width: 1280px !important; height: auto !important; overflow: visible !important; display: block !important; }
  html, body { width: 1280px !important; height: auto !important; overflow: visible !important; background-color: #000 !important; }
  
  .slide {
    display: flex !important; position: relative !important; width: 1280px !important; height: 720px !important;
    transform: none !important; opacity: 1 !important; visibility: visible !important;
    page-break-after: always !important; page-break-inside: avoid !important; break-after: page !important; break-inside: avoid !important;
    margin: 0 !important; padding: 0 !important; box-shadow: none !important; border: none !important;
  }
  .slide:last-of-type { page-break-after: auto !important; break-after: auto !important; }
  .slide.layout-standard { display: grid !important; grid-template-rows: auto 1fr auto !important; grid-template-columns: 1fr !important; }
  
  /* Hide all UI elements */
  .toc-sidebar, .toc-overlay, .nav-progress, .bottom-controls, .laser-pointer, .lightbox-overlay, .fab-container, .nav-pill-container, .presenter-console-container, .sidebar-trigger {
    display: none !important;
  }
  .diagram-container, .code-container { page-break-inside: avoid !important; break-inside: avoid !important; }
}
</style>
</head>
<body class="theme-{{ theme_name }} {% if animations %}has-animations{% endif %}">
  <!-- TOC Sidebar -->
  <div class="toc-overlay" id="tocOverlay"></div>
  <div class="sidebar-trigger" id="sidebarTrigger"></div>
  <nav class="toc-sidebar" id="tocSidebar">
    <h3>Contenido</h3>
    <ul>
      {% set ns = namespace(seen_annex=false) %}
      {% for item in toc %}
        {% if item.is_annex and not ns.seen_annex %}
          <li class="toc-separator">── Anexos ──</li>
          {% set ns.seen_annex = true %}
        {% endif %}
        <li data-slide="{{ item.index }}" class="toc-item toc-level-{{ item.level }}{% if item.is_annex %} toc-annex{% endif %}">
          {% if item.is_annex %}
            <span class="toc-annex-badge">{{ item.annex_label }}</span>
          {% endif %}
          {{ item.title }}
        </li>
      {% endfor %}
    </ul>
  </nav>

  <!-- Presentation -->
  <div class="presentation-container" id="presentationContainer">
    {% for slide_html in slides %}
    {{ slide_html | safe }}
    {% endfor %}
  </div>

  <!-- Progress Bar -->
  <div class="nav-progress"><div class="nav-progress-fill" id="progressFill"></div></div>

  <!-- Navigation Pill (Centered at bottom) -->
  <div class="nav-pill-container" id="navPillContainer">
    {% if nav_arrows %}
    <button class="nav-arrow-btn" id="prevArrow" aria-label="Anterior" title="Anterior (← / Backspace)">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-svg"><polyline points="15 18 9 12 15 6"></polyline></svg>
    </button>
    {% endif %}
    <div class="slide-counter" id="slideCounter"></div>
    {% if nav_arrows %}
    <button class="nav-arrow-btn" id="nextArrow" aria-label="Siguiente" title="Siguiente (→ / Space)">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-svg"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </button>
    {% endif %}
  </div>

  <!-- Expandable FAB Menu (Bottom-right) -->
  <div class="fab-container" id="fabContainer">
    <div class="fab-menu" id="fabMenu">
      <button class="fs-btn fab-item" id="presenterBtn" aria-label="Consola de Presentador (P)" title="Consola de Presentador (P)">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-svg"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
      </button>
      <button class="fs-btn fab-item" id="fsBtn" aria-label="Pantalla Completa" title="Pantalla Completa (F)">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-svg"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"></path></svg>
      </button>
      <button class="fs-btn fab-item" id="clearBtn" aria-label="Limpiar Dibujos (C)" title="Limpiar Dibujos (C)">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-svg"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
      </button>
      <button class="fs-btn fab-item" id="drawBtn" aria-label="Dibujar (D)" title="Dibujar (D)">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-svg"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
      </button>
      <button class="fs-btn fab-item" id="laserBtn" aria-label="Puntero Láser (L)" title="Puntero Láser (L)">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-svg"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="3"></circle></svg>
      </button>
    </div>
    <button class="fs-btn fab-trigger" id="fabTrigger" aria-label="Herramientas" title="Herramientas (Menú)">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-svg fab-trigger-icon"><circle cx="12" cy="12" r="1"></circle><circle cx="12" cy="5" r="1"></circle><circle cx="12" cy="19" r="1"></circle></svg>
    </button>
  </div>

  <!-- Laser Pointer -->
  <div class="laser-pointer" id="laserPointer"></div>

  <!-- Spotlight Mask Overlay -->
  <div class="spotlight-overlay" id="spotlightOverlay"></div>
  <div class="spotlight-tooltip" id="spotlightTooltip"></div>


  <!-- Drawing Canvas -->
  <canvas class="drawing-canvas" id="drawingCanvas"></canvas>

  <!-- SVG Lightbox -->
  <div class="lightbox-overlay" id="lightboxOverlay">
    <button class="lightbox-close" id="lightboxClose">✕</button>
    <div class="lightbox-content" id="lightboxContent">
      <div id="lightboxWrapper" style="transform-origin: center; cursor: grab; display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; transition: transform 0.15s cubic-bezier(0.16, 1, 0.3, 1);"></div>
    </div>
    <div class="lightbox-controls">
      <button class="lightbox-btn" id="zoomIn" title="Acercar">＋</button>
      <button class="lightbox-btn" id="zoomOut" title="Alejar">－</button>
      <button class="lightbox-btn" id="zoomReset" title="Restaurar">↺</button>
    </div>
  </div>

  <!-- Presenter Console Container -->
  <div class="presenter-console-container" id="presenterConsole">
    <div class="presenter-left-panel">
      <div class="presenter-preview-box">
        <div class="presenter-preview-label">Slide Actual</div>
        <div class="slide-frame" id="presenterCurrentFrame"></div>
      </div>
      <div class="presenter-preview-box">
        <div class="presenter-preview-label">Siguiente Slide</div>
        <div class="slide-frame" id="presenterNextFrame"></div>
      </div>
    </div>
    
    <div class="presenter-right-panel">
      <div class="presenter-timer-box">
        <div style="display: flex; gap: 30px;">
          <div class="timer-segment">
            <span class="timer-label">Hora Local</span>
            <span class="timer-value" id="presenterClock">00:00:00</span>
          </div>
          <div class="timer-segment">
            <span class="timer-label">Tiempo Transcurrido</span>
            <span class="timer-value" id="presenterStopwatch">00:00</span>
          </div>
        </div>
        <button class="timer-reset-btn" id="presenterResetTimer">Reiniciar Cronómetro</button>
      </div>
      
      <div class="presenter-notes-box">
        <div class="presenter-preview-label">Notas del Orador</div>
        <div class="presenter-notes-content" id="presenterSpeakerNotes"></div>
      </div>
    </div>
    
    <div class="presenter-bottom-bar">
      <div class="presenter-slide-info" id="presenterSlideInfo">Slide 1 / 1</div>
      <div class="presenter-nav-buttons">
        <button class="presenter-nav-btn" id="presenterPrevBtn">◀ Anterior</button>
        <button class="presenter-nav-btn" id="presenterNextBtn">Siguiente ▶</button>
      </div>
      <button class="presenter-close-btn" id="presenterCloseConsole">Cerrar Consola</button>
    </div>
  </div>

  <script>
  // Custom Elements definition for SmartArt Components
  class PmdSmartArtBase extends HTMLElement {
    connectedCallback() {
      const items = Array.from(this.querySelectorAll(this.constructor.itemSelector));
      if (items.length === 0) return;

      items.forEach(item => {
        item.removeAttribute('data-step');
        item.classList.remove('step-hidden', 'step-visible');
      });

      const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      svg.setAttribute('class', 'smartart-svg');
      svg.setAttribute('viewBox', this.constructor.viewBox);
      svg.setAttribute('preserveAspectRatio', 'xMidYMid meet');
      this.appendChild(svg);
      this.svg = svg;

      const isSteps = this._isStepsMode();
      this.renderGeometry(svg, items, isSteps);

      items.forEach(item => item.style.display = 'none');
      this._setupMutationObserver(items);
    }

    _isStepsMode() {
      const animated = this.getAttribute('data-animated');
      return animated === null ? this.getAttribute('data-steps') === 'true' : animated !== 'false';
    }

    _createGroup(parent, isSteps, color) {
      const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
      const groupClass = isSteps ? 'smartart-svg-group step-hidden' : 'smartart-svg-group svg-step-visible';
      g.setAttribute('class', groupClass);
      if (isSteps) g.setAttribute('data-step', '');
      g.setAttribute('data-color', color);
      parent.appendChild(g);
      return g;
    }

    _createCard(parent, x, y, w, h, label, desc) {
      const cardFo = document.createElementNS('http://www.w3.org/2000/svg', 'foreignObject');
      cardFo.setAttribute('class', 'smartart-card-fo');
      cardFo.setAttribute('x', String(x));
      cardFo.setAttribute('y', String(y));
      cardFo.setAttribute('width', String(w));
      cardFo.setAttribute('height', String(h));
      const descHtml = desc ? `<div class="smartart-card-desc">${desc}</div>` : '';
      cardFo.innerHTML = `<div class="smartart-card-container"><div class="smartart-card-label">${label}</div>${descHtml}</div>`;
      parent.appendChild(cardFo);
    }

    _setupMutationObserver(originalItems) {
      if (!this._isStepsMode()) return;
      this.mutationObserver = new MutationObserver(mutations => {
        mutations.forEach(mutation => {
          if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
            const item = mutation.target;
            const idx = originalItems.indexOf(item);
            if (idx !== -1) {
              const groups = this.svg.querySelectorAll('.smartart-svg-group');
              const g = groups[idx];
              if (g) {
                if (item.classList.contains('step-visible')) {
                  g.classList.add('svg-step-visible');
                  g.classList.remove('svg-step-hidden');
                  g.classList.remove('step-hidden');
                } else if (item.classList.contains('step-hidden')) {
                  g.classList.remove('svg-step-visible');
                  g.classList.add('svg-step-hidden');
                }
              }
            }
          }
        });
      });
      originalItems.forEach(item => {
        this.mutationObserver.observe(item, { attributes: true, attributeFilter: ['class'] });
      });
    }

    disconnectedCallback() {
      if (this.mutationObserver) this.mutationObserver.disconnect();
    }
  }

  /* --- PmdPyramid --- */
  class PmdPyramid extends PmdSmartArtBase {
    static get viewBox() { return '0 0 1200 800'; }
    static get itemSelector() { return '.pmd-pyramid-item'; }

    renderGeometry(svg, items, isSteps) {
      const layout = this.getAttribute('data-layout') || 'pyramid';
      const isFunnel = layout === 'funnel' || layout === 'embudo' || layout === 'inverted';
      const N = items.length;
      const xCenter = 400;
      const wTop = isFunnel ? 700 : 0;
      const wBottom = isFunnel ? 0 : 700;
      const yStart = 50;
      const H = 700;
      const h = H / N;
      const cardX = 800;
      const cardW = 380;
      const cardH = 120;

       for (let i = 0; i < N; i++) {
         const item = items[i];
         const color = item.getAttribute('data-color') || '1';
         const kt = isFunnel ? (N - i) / N : i / N;
        const kb = isFunnel ? (N - (i + 1)) / N : (i + 1) / N;
        const wt = wTop + (wBottom - wTop) * kt;
        const wb = wTop + (wBottom - wTop) * kb;
        const yTop = yStart + i * h;
        const yBottom = yStart + (i + 1) * h;
        const yMid = (yTop + yBottom) / 2;
        const xtl = xCenter - wt / 2;
        const xtr = xCenter + wt / 2;
        const xbl = xCenter - wb / 2;
        const xbr = xCenter + wb / 2;
        const xRightBoundary = xCenter + (wt + wb) / 4;
        const cardY = Math.max(5, Math.min(800 - cardH - 5, yMid - cardH / 2));

        const g = this._createGroup(svg, isSteps, color);

        const dLeft = `M ${xCenter},${yTop} L ${xtl},${yTop} L ${xbl},${yBottom} L ${xCenter},${yBottom} Z`;
        const pathLeft = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        pathLeft.setAttribute('d', dLeft);
        pathLeft.setAttribute('class', 'smartart-pyramid-left');
        g.appendChild(pathLeft);

        const dRight = `M ${xCenter},${yTop} L ${xtr},${yTop} L ${xbr},${yBottom} L ${xCenter},${yBottom} Z`;
        const pathRight = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        pathRight.setAttribute('d', dRight);
        pathRight.setAttribute('class', 'smartart-pyramid-right');
        g.appendChild(pathRight);

        const lineXMid = (xRightBoundary + cardX) / 2;
        const dLine = `M ${xRightBoundary},${yMid} L ${lineXMid},${yMid} L ${lineXMid},${cardY + cardH / 2} L ${cardX},${cardY + cardH / 2}`;
